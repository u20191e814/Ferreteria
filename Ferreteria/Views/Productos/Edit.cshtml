@using Ferreteria.DTOs
@model Ferreteria.DTOs.ProductoUpdateDto
@{
    ViewData["Title"] = "Editar Producto";
    var unidades = ViewBag.UnidadesMedida as IEnumerable<UnidadMedidaDto> ?? new List<UnidadMedidaDto>();
    var categorias = ViewBag.Categorias as IEnumerable<CategoriaDto> ?? new List<CategoriaDto>();
}
 

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
         
        <h2 class="mb-0">Modificar producto #@Model.Id</h2>
      
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info">
            <i class="fas fa-eye me-2"></i>Ver Detalle
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver
        </a>
    </div>
</div>

<form asp-action="Edit" method="post" id="formEditar" class="needs-validation" novalidate>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="FechaCreacion" />
    <input type="hidden" asp-for="StockActual" /> @* Stock actual no editable directamente *@

    <div class="row g-4">
        <div class="col-lg-8">
            @* Info del producto (solo lectura) *@
            <div class="info-badge mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted">Producto creado el</small>
                        <strong class="d-block">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>
                    <div class="text-center">
                        <small class="text-muted">Stock Actual</small>
                        <strong class="d-block fs-4 text-success">@Model.StockActual.ToString("N2")</strong>
                    </div>
                    <div class="text-end">
                        <small class="text-muted">Estado</small>
                        <span class="badge @(Model.Activo ? "bg-success" : "bg-secondary") d-block">
                            @(Model.Activo ? "Activo" : "Inactivo")
                        </span>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0"><i class="fas fa-box me-2 text-primary"></i>Información del Producto</h5>
                </div>
                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Codigo" class="form-label fw-bold">
                                Código <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-barcode text-muted"></i>
                                </span>
                                <input asp-for="Codigo" class="form-control" required maxlength="50" id="codigo" onblur="validarCodigoUnico()">
                            </div>
                            <span asp-validation-for="Codigo" class="text-danger small"></span>
                            <div id="codigoFeedback" class="form-text"></div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label fw-bold">
                                Nombre del Producto <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Nombre" class="form-control" required maxlength="200" id="nombre">
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        @* CATEGORÍA - Búsqueda desde BD *@
                        <div class="col-md-6">
                            <label asp-for="CategoriaId" class="form-label fw-bold">Categoría</label>
                            <input type="hidden" asp-for="CategoriaId" id="categoriaId" />

                            <div class="position-relative">
                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="fas fa-tags text-muted"></i>
                                    </span>
                                    <input type="text" class="form-control" id="buscadorCategoria"
                                           placeholder="Buscar o seleccionar categoría..." autocomplete="off"
                                           value="@Model.CategoriaNombre">
                                    <button type="button" class="btn btn-outline-primary" onclick="mostrarModalGestionCategorias()"
                                            title="Gestionar categorías (Editar, Eliminar, Nueva)">
                                        <i class="fas fa-th-large"></i>
                                    </button>
                                </div>

                                @* Indicador de carga *@
                                <div id="indicadorCargaCategoria" class="position-absolute end-0 top-0 mt-2 me-5 d-none">
                                    <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                </div>
                            </div>

                            <div id="resultadosCategoria" class="list-group shadow-lg position-absolute w-100"
                                 style="z-index: 1000; max-height: 200px; overflow-y: auto; display: none;">
                            </div>

                            @* Info de categoría seleccionada *@
                            <div id="infoCategoria" class="@(Model.CategoriaId.HasValue ? "" : "d-none") mt-2">
                                <div class="alert alert-primary p-2 mb-0 border-0 categoria-seleccionada">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-tag me-2 text-primary"></i>
                                            <span id="nombreCategoriaSeleccionada" class="fw-bold">@(Model.CategoriaNombre ?? "-")</span>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="limpiarCategoria()" title="Cambiar categoría">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div id="sinCategoria" class="form-text">
                                <i class="fas fa-info-circle me-1"></i>Seleccione una categoría o déjelo vacío
                            </div>
                        </div>



                        @* UNIDAD DE MEDIDA desde BD *@
                        <div class="col-md-6">
                            <label asp-for="UnidadMedidaId" class="form-label fw-bold">
                                Unidad de Medida <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-ruler text-muted"></i></span>
                                <select asp-for="UnidadMedidaId" class="form-select" required id="unidadMedida">
                                    <option value="">Seleccionar...</option>
                                    @foreach (var um in unidades)
                                    {
                                        <option value="@um.Id" data-abrev="@um.Abreviatura" selected="@(Model.UnidadMedidaId == um.Id ? "selected" : null)">
                                            @um.NombreCompleto
                                        </option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="UnidadMedidaId" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3" maxlength="500" id="descripcion"></textarea>
                            <div class="form-text d-flex justify-content-between">
                                <span>Información adicional para el catálogo</span>
                                <span id="contadorDesc">@(Model.Descripcion?.Length ?? 0)/500</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Precios y Stock *@
            <div class="card mt-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0"><i class="fas fa-dollar-sign me-2 text-success"></i>Precios y Stock</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="PrecioCompra" class="form-label fw-bold">
                                Precio de Compra <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">S/</span>
                                <input asp-for="PrecioCompra" type="number" class="form-control"
                                       step="1" min="0" required id="precioCompra" onchange="calcularMargen()">
                            </div>
                            <span asp-validation-for="PrecioCompra" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="PrecioVenta" class="form-label fw-bold">
                                Precio de Venta <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">S/</span>
                                <input asp-for="PrecioVenta" type="number" class="form-control"
                                       step="1" min="0" required id="precioVenta" onchange="calcularMargen()">
                            </div>
                            <span asp-validation-for="PrecioVenta" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Margen Actual</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-percentage text-muted"></i></span>
                                <input type="text" class="form-control" id="margenPorcentaje" readonly>
                            </div>
                            <div id="margenAlert" class="form-text"></div>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="StockMinimo" class="form-label fw-bold">
                                Stock Mínimo <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input asp-for="StockMinimo" type="number" class="form-control"
                                       step="1" min="0" required id="stockMinimo">
                                <span class="input-group-text bg-light" id="abreviaturaMinimo">und</span>
                            </div>
                            <span asp-validation-for="StockMinimo" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Stock Actual (Solo lectura)</label>
                            <div class="input-group">
                                <input type="text" class="form-control bg-light" value="@Model.StockActual.ToString("N2")" readonly>
                                <span class="input-group-text bg-light" id="abreviaturaStock">und</span>
                            </div>
                            <div class="form-text">
                                <a href="#" onclick="mostrarModalAjusteStock()">Ajustar stock</a> si es necesario
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="UbicacionAlmacen" class="form-label fw-bold">Ubicación</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-map-marker-alt text-muted"></i></span>
                                <input asp-for="UbicacionAlmacen" class="form-control" maxlength="100">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Proveedor *@
            <div class="card mt-4">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-truck me-2 text-info"></i>Proveedor</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="mostrarModalProveedores()">
                        <i class="fas fa-list me-1"></i>Ver Todos
                    </button>
                </div>
                <div class="card-body p-4">
                    <input type="hidden" asp-for="idProveedor" id="idProveedor" />

                    <div class="position-relative">
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-light"><i class="fas fa-building text-muted"></i></span>
                            <input type="text" class="form-control" id="buscadorProveedor"
                                   placeholder="Buscar proveedor..." autocomplete="off"
                                   value="@Model.ProveedorNombre">
                            <button type="button" class="btn btn-outline-success" onclick="mostrarModalNuevoProveedor()">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                        <div id="indicadorCargaProveedor" class="position-absolute end-0 top-50 mt-4 me-5 d-none">
                            <span class="spinner-border spinner-border-sm text-primary"></span>
                        </div>
                    </div>

                    <div id="resultadosProveedor" class="list-group shadow-lg position-absolute w-100"
                         style="z-index: 1000; max-height: 300px; overflow-y: auto; display: none;"></div>

                    <div id="infoProveedor" class="@(Model.idProveedor.HasValue ? "" : "d-none") mt-3">
                        <div class="alert alert-info p-3 mb-0 border-0 proveedor-seleccionado">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 fw-bold" id="nombreProveedorSeleccionado">@(Model.ProveedorNombre ?? "-")</h6>
                                    <span class="badge bg-primary">Proveedor seleccionado</span>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="limpiarProveedor()">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Estado Activo/Inactivo *@
            <div class="card mt-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0"><i class="fas fa-toggle-on me-2 text-warning"></i>Estado del Producto</h5>
                </div>
                <div class="card-body p-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="Activo" id="activoSwitch" style="width: 3em; height: 1.5em;">
                        <label class="form-check-label ms-2" for="activoSwitch">
                            <span id="estadoTexto" class="fw-bold">@(Model.Activo ? "Activo" : "Inactivo")</span>
                            <div class="form-text">Desactive para ocultar el producto del catálogo</div>
                        </label>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <button type="button" class="btn btn-outline-danger btn-lg" onclick="confirmarEliminar()">
                    <i class="fas fa-trash me-2"></i>Eliminar producto
                </button>
                <div>
                    <button type="button" class="btn btn-outline-warning btn-lg me-2" onclick="mostrarModalAjusteStock()">
                        <i class="fas fa-balance-scale me-2"></i>Ajustar Stock
                    </button>

                </div>
                <div class="d-flex gap-2">
                    
                    <button type="submit" class="btn btn-primary btn-lg" id="btnGuardar">
                        <i class="fas fa-save me-2"></i>Guardar Cambios
                    </button>
                </div>
            </div>

            @* HISTORIAL DE MOVIMIENTOS *@
            <div class="card mt-4">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-history me-2 text-secondary"></i>Historial de Movimientos</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="cargarHistorialMovimientos()">
                        <i class="fas fa-sync-alt me-1"></i>Actualizar
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0" id="tablaHistorial">
                            <thead class="table-light">
                                <tr>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Cantidad</th>
                                    <th>Stock Ant.</th>
                                    <th>Stock Nuevo</th>
                                    <th>Usuario</th>
                                    <th>Observación</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyHistorial">
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-3">
                                        <i class="fas fa-spinner fa-spin me-2"></i>Cargando historial...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    
                </div>
            </div>

            
        </div>

        @* Columna Preview *@
        <div class="col-lg-4">
            <div class="card sticky-top" style="top: 20px; z-index: 100;">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0"><i class="fas fa-eye me-2 text-warning"></i>Vista Previa</h5>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-3">
                        <div class="bg-light rounded p-4 mb-3" style="height: 150px;">
                            <i class="fas fa-box-open fa-3x text-muted opacity-25" id="previewIcon"></i>
                        </div>
                    </div>

                    <h5 class="mb-1" id="previewNombre">@Model.Nombre</h5>
                    <p class="text-muted small mb-2" id="previewCodigo">@Model.Codigo</p>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge @(Model.CategoriaId.HasValue ? "bg-secondary" : "bg-light text-dark")" id="previewCategoria">
                            @(Model.CategoriaNombre ?? "Sin categoría")
                        </span>
                        <span class="badge bg-primary" id="previewUnidad">und</span>
                    </div>

                    <hr>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <small class="text-muted d-block">Precio Venta</small>
                            <strong class="text-primary fs-5" id="previewPrecio">S/ @Model.PrecioVenta.ToString("N2")</strong>
                        </div>
                        <div class="col-6 text-end">
                            <small class="text-muted d-block">Stock</small>
                            <strong class="text-success" id="previewStock">@Model.StockActual.ToString("N2") und</strong>
                        </div>
                    </div>

                    <div class="alert alert-info small mb-0" id="previewMargen">
                        <i class="fas fa-calculator me-2"></i>Calculando margen...
                    </div>

                    <div class="mt-3 pt-3 border-top" id="previewProveedor" style="@(Model.idProveedor.HasValue ? "" : "display:none")">
                        <small class="text-muted d-block mb-1">Proveedor</small>
                        <span class="badge bg-info text-dark">
                            <i class="fas fa-truck me-1"></i><span id="textoProveedorPreview">@(Model.ProveedorNombre ?? "-")</span>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@* ==================== MODALES ==================== *@

@* Modal Confirmar Eliminar *@
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i>Confirmar Eliminación</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Está seguro de eliminar el producto <strong id="nombreProductoEliminar">@Model.Nombre</strong>?</p>

                <div class="alert alert-warning">
                    <i class="fas fa-info-circle me-2"></i>
                    <span id="mensajeEliminar">
                        Esta acción no se puede deshacer. Si el producto tiene ventas asociadas, solo se desactivará.
                    </span>
                </div>

                <div id="dependenciasEliminar" class="d-none">
                    <h6>Dependencias encontradas:</h6>
                    <ul class="list-unstyled">
                        <li id="tieneVentasMsg" class="d-none text-danger"><i class="fas fa-times-circle me-2"></i>Tiene ventas realizadas</li>
                        <li id="tieneMovimientosMsg" class="d-none text-warning"><i class="fas fa-exclamation-circle me-2"></i>Tiene movimientos de inventario</li>
                    </ul>
                </div>
            </div>
            <div class="modal-footer">
                 
                <form asp-action="Delete" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Eliminar Producto
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@* Modales de Categorías, Proveedores (mismos que en Create) *@
<div class="modal fade" id="modalCategorias" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-tags me-2"></i>Seleccionar Categoría</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" class="form-control" id="busquedaModalCategoria"
                               placeholder="Buscar categoría..." onkeyup="filtrarCategoriasModal()">
                    </div>
                </div>
                <div id="gridCategoriasModal" class="row g-3">
                    @foreach (var cat in categorias)
                    {
                        <div class="col-md-4 categoria-item" data-nombre="@cat.Nombre.ToLower()">
                            <div class="card h-100 categoria-card @(Model.CategoriaId == cat.Id ? "active" : "")"
                                 onclick="seleccionarCategoriaDesdeModal(@cat.Id, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(cat.Nombre))')">
                                <div class="card-body text-center">
                                    <i class="fas fa-tag fa-2x @(Model.CategoriaId == cat.Id ? "text-white" : "text-primary") mb-2"></i>
                                    <h6 class="card-title mb-1">@cat.Nombre</h6>
                                    @if (!string.IsNullOrEmpty(cat.Descripcion))
                                    {
                                        <small class="@(Model.CategoriaId == cat.Id ? "text-white-50" : "text-muted") d-block text-truncate">@cat.Descripcion</small>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>



@* ==================== MODALES ==================== *@
@* MODAL DE GESTIÓN COMPLETA DE CATEGORÍAS *@
<div class="modal fade" id="modalGestionCategorias" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-tags me-2"></i>Gestionar Categorías
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @* Toolbar *@
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="input-group w-50">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" class="form-control" id="busquedaGestionCategoria"
                               placeholder="Buscar categoría..." onkeyup="filtrarCategoriasGestion()">
                    </div>
                    <button type="button" class="btn btn-success" onclick="mostrarModalNuevaCategoriaDesdeGestion()">
                        <i class="fas fa-plus me-2"></i>Nueva Categoría
                    </button>
                </div>

                @* Loading *@
                <div id="cargaGestionCategorias" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Cargando categorías...</p>
                </div>

                @* Grid de Categorías *@
                <div id="gridGestionCategorias" class="d-none">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40%">Nombre</th>
                                    <th style="width: 35%">Descripción</th>
                                    <th style="width: 10%" class="text-center">Productos</th>
                                    <th style="width: 15%" class="text-center">Acciones</th>
                                </tr>
                            </thead>
