                    <label class="form-label fw-bold">Motivo / Observación <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="motivoAjuste" rows="3"
                              placeholder="Ej: Inventario físico, mercancía dañada, corrección de error..."
                              minlength="5" maxlength="500"></textarea>
                    <div class="form-text">Mínimo 5 caracteres. Este motivo quedará registrado en el historial.</div>
