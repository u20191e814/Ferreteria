</div>
@section Scripts {
    <script>
        // Variables globales
        let categoriaSeleccionada = { id: @(Model.CategoriaId?.ToString() ?? "null"), nombre: '@Html.Raw(Model.CategoriaNombre ?? "")' };
        let proveedorSeleccionado = { id: @(Model.idProveedor?.ToString() ?? "null"), nombre: '@Html.Raw(Model.ProveedorNombre ?? "")' };
        let productoId = @Model.Id;
        let timeoutBusqueda = null;
         let todasLasCategorias = @Html.Raw(Json.Serialize(categorias.Select(c => new { c.Id, c.Nombre, c.Descripcion })));
        // Inicialización
        document.addEventListener('DOMContentLoaded', function() {
            // Actualizar abreviatura unidad
            const umSelect = document.getElementById('unidadMedida');
            if (umSelect.selectedIndex > 0) {
                const abrev = umSelect.options[umSelect.selectedIndex].getAttribute('data-abrev');
                document.getElementById('abreviaturaMinimo').textContent = abrev;
                document.getElementById('abreviaturaStock').textContent = abrev;
                document.getElementById('previewUnidad').textContent = abrev;
            }

            // Contador descripción
            document.getElementById('descripcion').addEventListener('input', function() {
                document.getElementById('contadorDesc').textContent = `${this.value.length}/500`;
            });

            // Switch estado
            document.getElementById('activoSwitch').addEventListener('change', function() {
                document.getElementById('estadoTexto').textContent = this.checked ? 'Activo' : 'Inactivo';
                document.getElementById('estadoTexto').className = this.checked ? 'fw-bold text-success' : 'fw-bold text-secondary';
            });

            // Calcular margen inicial
            calcularMargen();

            // Buscadores con debounce
            setupBuscador('buscadorCategoria', 'indicadorCargaCategoria', buscarCategoriasAjax, 'resultadosCategoria');
            setupBuscador('buscadorProveedor', 'indicadorCargaProveedor', buscarProveedoresAjax, 'resultadosProveedor');

            // Preview inputs
            ['nombre', 'codigo', 'precioVenta'].forEach(id => {
                document.getElementById(id)?.addEventListener('input', actualizarPreview);
            });
        });

        function setupBuscador(inputId, spinnerId, callback, resultadosId) {
            const input = document.getElementById(inputId);
            input.addEventListener('input', function() {
                clearTimeout(timeoutBusqueda);
                const valor = this.value.trim();

                if (valor.length >= 2) {
                    document.getElementById(spinnerId).classList.remove('d-none');
                    timeoutBusqueda = setTimeout(() => callback(valor), 300);
                } else {
                    document.getElementById(resultadosId).style.display = 'none';
                    document.getElementById(spinnerId).classList.add('d-none');
                }
            });
        }

        // ========== CATEGORÍAS ==========
        async function buscarCategoriasAjax(termino) {
            try {
                const response = await fetch(`/Productos/BuscarCategorias?texto=${encodeURIComponent(termino)}`);
                const categorias = await response.json();
                mostrarResultadosCategorias(categorias);
            } catch (error) {
                console.error('Error:', error);
            } finally {
                document.getElementById('indicadorCargaCategoria').classList.add('d-none');
            }
        }

        function mostrarResultadosCategorias(categorias) {
            const contenedor = document.getElementById('resultadosCategoria');
            if (categorias.length === 0) {
                contenedor.innerHTML = '<div class="list-group-item text-muted text-center py-3">No se encontraron categorías</div>';
            } else {
                contenedor.innerHTML = categorias.map(c => `
                    <button type="button" class="list-group-item list-group-item-action"
                            onclick="seleccionarCategoria(${c.id}, '${escapeHtml(c.nombre)}')">
                        <strong>${escapeHtml(c.nombre)}</strong>
                        ${c.descripcion ? `<div class="small text-muted">${escapeHtml(c.descripcion)}</div>` : ''}
                    </button>
                `).join('');
            }
            contenedor.style.display = 'block';
        }

        function seleccionarCategoria(id, nombre) {
            categoriaSeleccionada = { id, nombre };
            document.getElementById('categoriaId').value = id;
            document.getElementById('nombreCategoriaSeleccionada').textContent = nombre;
            document.getElementById('infoCategoria').classList.remove('d-none');
            document.getElementById('resultadosCategoria').style.display = 'none';
            document.getElementById('buscadorCategoria').value = '';
            document.getElementById('previewCategoria').textContent = nombre;
            document.getElementById('previewCategoria').className = 'badge bg-secondary';
        }

        function limpiarCategoria() {
            categoriaSeleccionada = null;
            document.getElementById('categoriaId').value = '';
            document.getElementById('infoCategoria').classList.add('d-none');
            document.getElementById('previewCategoria').textContent = 'Sin categoría';
            document.getElementById('previewCategoria').className = 'badge bg-light text-dark';
        }

        function mostrarModalCategorias() {
            new bootstrap.Modal(document.getElementById('modalCategorias')).show();
        }

        

        function seleccionarCategoriaDesdeModal(id, nombre) {
            seleccionarCategoria(id, nombre);
            bootstrap.Modal.getInstance(document.getElementById('modalCategorias')).hide();
        }

        function filtrarCategoriasModal() {
            const termino = document.getElementById('busquedaModalCategoria').value.toLowerCase();
            document.querySelectorAll('.categoria-item').forEach(item => {
                const nombre = item.getAttribute('data-nombre');
                item.classList.toggle('d-none', !nombre.includes(termino));
            });
        }

        async function crearCategoriaRapida() {
            const nombre = document.getElementById('nuevaCategoriaNombre').value.trim();
            const descripcion = document.getElementById('nuevaCategoriaDescripcion').value.trim();
            const errorDiv = document.getElementById('errorNuevaCategoria');

            if (nombre.length < 2) {
                errorDiv.textContent = 'El nombre debe tener al menos 2 caracteres';
                errorDiv.classList.remove('d-none');
                return;
            }

            try {
                const response = await fetch('/Productos/CrearCategoriaRapida', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre, descripcion })
                });

                const result = await response.json();
                if (!response.ok) throw new Error(result.error);

                seleccionarCategoria(result.id, result.nombre);
                bootstrap.Modal.getInstance(document.getElementById('modalNuevaCategoria')).hide();

            } catch (error) {
                errorDiv.textContent = error.message;
                errorDiv.classList.remove('d-none');
            }
        }
        ////nuevas
        function mostrarModalGestionCategorias() {
            const modal = new bootstrap.Modal(document.getElementById('modalGestionCategorias'));
            modal.show();
            cargarCategoriasParaGestion();
        }

        async function cargarCategoriasParaGestion() {
            const carga = document.getElementById('cargaGestionCategorias');
            const grid = document.getElementById('gridGestionCategorias');
            const sinResultados = document.getElementById('sinResultadosGestionCategorias');
            const estadoVacio = document.getElementById('estadoVacioGestionCategorias');
            const tbody = document.getElementById('tbodyGestionCategorias');

            // Reset UI
            carga.classList.remove('d-none');
            grid.classList.add('d-none');
            sinResultados.classList.add('d-none');
            estadoVacio.classList.add('d-none');

            try {
                const response = await fetch('/Productos/GetCategoriasParaGestion');
                if (!response.ok) throw new Error('Error al cargar');

                categoriasGestion = await response.json();
                carga.classList.add('d-none');

                if (categoriasGestion.length === 0) {
                    estadoVacio.classList.remove('d-none');
                    return;
                }

                renderizarTablaCategorias(categoriasGestion);
                grid.classList.remove('d-none');

            } catch (error) {
                console.error('Error:', error);
                carga.classList.add('d-none');
                tbody.innerHTML = `
                    <tr>
                        <td colspan="4" class="text-center text-danger py-3">
                            <i class="fas fa-exclamation-circle me-2"></i>Error al cargar categorías
                        </td>
                    </tr>`;
                grid.classList.remove('d-none');
            }
        }

        function renderizarTablaCategorias(categorias) {
            const tbody = document.getElementById('tbodyGestionCategorias');

            tbody.innerHTML = categorias.map(c => `
                <tr data-id="${c.id}" data-nombre="${escapeHtml(c.nombre).toLowerCase()}">
                    <td>
                        <div class="d-flex align-items-center">
                            <i class="fas fa-tag text-primary me-2"></i>
                            <strong>${escapeHtml(c.nombre)}</strong>
                            ${c.id === categoriaSeleccionada?.id ? '<span class="badge bg-primary ms-2">Seleccionada</span>' : ''}
                        </div>
                    </td>
                    <td>
                        <span class="text-muted small">${escapeHtml(c.descripcion) || '-'}</span>
                    </td>
                    <td class="text-center">
                        <span class="badge ${c.cantidadProductos > 0 ? 'bg-info' : 'bg-secondary'}">
                            ${c.cantidadProductos}
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm">
                            <button type="button" class="btn btn-outline-warning"
                                    onclick="mostrarModalEditarCategoria(${c.id}, '${escapeHtml(c.nombre)}', '${escapeHtml(c.descripcion || '')}')"
                                    title="Editar">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button type="button" class="btn btn-outline-danger ${!c.puedeEliminar ? 'disabled' : ''}"
                                    onclick="${c.puedeEliminar ? `mostrarModalEliminarCategoria(${c.id}, '${escapeHtml(c.nombre)}', ${c.cantidadProductos})` : ''}"
                                    title="${c.puedeEliminar ? 'Eliminar' : 'Tiene productos asociados'}">
                                <i class="fas fa-trash"></i>
                            </button>
                            <button type="button" class="btn btn-outline-primary"
                                    onclick="seleccionarCategoriaDesdeGestion(${c.id}, '${escapeHtml(c.nombre)}')"
                                    title="Seleccionar para producto">
                                <i class="fas fa-check"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        function filtrarCategoriasGestion() {
            const termino = document.getElementById('busquedaGestionCategoria').value.toLowerCase();
            const filtradas = categoriasGestion.filter(c => c.nombre.toLowerCase().includes(termino));

            const sinResultados = document.getElementById('sinResultadosGestionCategorias');
            const grid = document.getElementById('gridGestionCategorias');

            if (filtradas.length === 0 && termino !== '') {
                grid.classList.add('d-none');
                sinResultados.classList.remove('d-none');
            } else {
                sinResultados.classList.add('d-none');
                grid.classList.remove('d-none');
                renderizarTablaCategorias(filtradas);
            }
        }

        // ============ EDITAR CATEGORÍA ============

        function mostrarModalEditarCategoria(id, nombre, descripcion) {
            document.getElementById('editarCategoriaId').value = id;
            document.getElementById('editarCategoriaNombre').value = nombre;
            document.getElementById('editarCategoriaDescripcion').value = descripcion;
            document.getElementById('errorEditarCategoria').classList.add('d-none');

            const modal = new bootstrap.Modal(document.getElementById('modalEditarCategoria'));
            modal.show();
        }

        async function guardarEdicionCategoria() {
            const id = parseInt(document.getElementById('editarCategoriaId').value);
            const nombre = document.getElementById('editarCategoriaNombre').value.trim();
            const descripcion = document.getElementById('editarCategoriaDescripcion').value.trim();
            const errorDiv = document.getElementById('errorEditarCategoria');
        }
             // ============ NUEVA CATEGORÍA (Integrada) ============

        function mostrarModalNuevaCategoriaDesdeGestion() {
            // Limpiar formulario
            document.getElementById('nuevaCategoriaNombre').value = '';
            document.getElementById('nuevaCategoriaDescripcion').value = '';
            document.getElementById('errorNuevaCategoria').classList.add('d-none');

            const modal = new bootstrap.Modal(document.getElementById('modalNuevaCategoria'));
            modal.show();
        }

        // Sobrescribir función existente para también refrescar gestión
        const crearCategoriaRapidaOriginal = crearCategoriaRapida;
        crearCategoriaRapida = async function() {
            const nombre = document.getElementById('nuevaCategoriaNombre').value.trim();
            const descripcion = document.getElementById('nuevaCategoriaDescripcion').value.trim();
            const errorDiv = document.getElementById('errorNuevaCategoria');

            if (nombre.length < 2) {
                errorDiv.textContent = 'El nombre debe tener al menos 2 caracteres';
                errorDiv.classList.remove('d-none');
                return;
            }

            try {
                const response = await fetch('/Productos/CrearCategoriaRapida', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: JSON.stringify({ nombre: nombre, descripcion: descripcion })
                });

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(result.error || 'Error al crear categoría');
                }

                // Agregar a la lista local
                const nuevaCat = { id: result.id, nombre: result.nombre, descripcion: descripcion };
                todasLasCategorias.push(nuevaCat);

                // Seleccionar
                seleccionarCategoria(result.id, result.nombre);

                // Cerrar modal
                bootstrap.Modal.getInstance(document.getElementById('modalNuevaCategoria')).hide();

                // Refrescar gestión si está abierta
                const modalGestion = document.getElementById('modalGestionCategorias');
                if (modalGestion.classList.contains('show')) {
                    await cargarCategoriasParaGestion();
                }

                mostrarToast(`Categoría "${result.nombre}" creada correctamente`, 'success');

            } catch (error) {
                errorDiv.textContent = error.message;
                errorDiv.classList.remove('d-none');
            }
        };

        function seleccionarCategoriaDesdeGestion(id, nombre) {
            seleccionarCategoria(id, nombre);
            bootstrap.Modal.getInstance(document.getElementById('modalGestionCategorias')).hide();
        }
        async function guardarEdicionCategoria() {
            const id = parseInt(document.getElementById('editarCategoriaId').value);
            const nombre = document.getElementById('editarCategoriaNombre').value.trim();
            const descripcion = document.getElementById('editarCategoriaDescripcion').value.trim();
            const errorDiv = document.getElementById('errorEditarCategoria');
            // Validaciones
            if (nombre.length < 2) {
                errorDiv.textContent = 'El nombre debe tener al menos 2 caracteres';
                errorDiv.classList.remove('d-none');
                return;
            }

            try {
                const response = await fetch('/Productos/EditarCategoria', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: JSON.stringify({ id, nombre, descripcion })
                });

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(result.error || 'Error al actualizar');
                }

                // Actualizar lista local
                const index = todasLasCategorias.findIndex(c => c.id === id);
                if (index !== -1) {
                    todasLasCategorias[index].nombre = nombre;
                    todasLasCategorias[index].descripcion = descripcion;
                }

                // Si es la categoría seleccionada actualmente, actualizar UI
                if (categoriaSeleccionada?.id === id) {
                    categoriaSeleccionada.nombre = nombre;
                    document.getElementById('nombreCategoriaSeleccionada').textContent = nombre;
                    document.getElementById('previewCategoria').textContent = nombre;
                }

                // Cerrar modal y refrescar grid
                bootstrap.Modal.getInstance(document.getElementById('modalEditarCategoria')).hide();

                // Refrescar gestión
                await cargarCategoriasParaGestion();

                // Mostrar notificación de éxito (opcional)
                mostrarToast('Categoría actualizada correctamente', 'success');

            } catch (error) {
                errorDiv.textContent = error.message;
                errorDiv.classList.remove('d-none');
            }
        }

          // ============ ELIMINAR CATEGORÍA ============

        function mostrarModalEliminarCategoria(id, nombre, cantidadProductos) {
            document.getElementById('eliminarCategoriaId').value = id;
            document.getElementById('eliminarCategoriaNombre').textContent = nombre;

            const alerta = document.getElementById('alertaProductosAsociados');
            const btnConfirmar = document.getElementById('btnConfirmarEliminar');

            if (cantidadProductos > 0) {
                document.getElementById('cantidadProductosEliminar').textContent = cantidadProductos;
                alerta.classList.remove('d-none');
                btnConfirmar.disabled = true;
                btnConfirmar.classList.add('disabled');
            } else {
                alerta.classList.add('d-none');
                btnConfirmar.disabled = false;
                btnConfirmar.classList.remove('disabled');
            }

            document.getElementById('errorEliminarCategoria').classList.add('d-none');

            const modal = new bootstrap.Modal(document.getElementById('modalEliminarCategoria'));
            modal.show();
        }

        async function confirmarEliminarCategoria() {
            const id = parseInt(document.getElementById('eliminarCategoriaId').value);
            const errorDiv = document.getElementById('errorEliminarCategoria');

            try {
                const response = await fetch('/Productos/EliminarCategoria?id='+ id );

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(result.error || 'Error al eliminar');
                }

                // Si la categoría eliminada estaba seleccionada, limpiar selección
                if (categoriaSeleccionada?.id === id) {
                    limpiarCategoria();
                }

                // Remover de lista local
                todasLasCategorias = todasLasCategorias.filter(c => c.id !== id);

                // Cerrar modal y refrescar
                bootstrap.Modal.getInstance(document.getElementById('modalEliminarCategoria')).hide();
                await cargarCategoriasParaGestion();

                mostrarToast('Categoría eliminada correctamente', 'success');

            } catch (error) {
                errorDiv.textContent = error.message;
                errorDiv.classList.remove('d-none');
            }
        }

        // ========== PROVEEDORES ==========
        async function buscarProveedoresAjax(termino) {
            try {
                const response = await fetch(`/Productos/BuscarProveedores?texto=${encodeURIComponent(termino)}`);
                const proveedores = await response.json();
                mostrarResultadosProveedores(proveedores);
            } catch (error) {
                console.error('Error:', error);
            } finally {
                document.getElementById('indicadorCargaProveedor').classList.add('d-none');
            }
        }

        function mostrarResultadosProveedores(proveedores) {
            const contenedor = document.getElementById('resultadosProveedor');
            if (proveedores.length === 0) {
                contenedor.innerHTML = '<div class="list-group-item text-muted text-center">No se encontraron proveedores</div>';
            } else {
                contenedor.innerHTML = proveedores.map(p => `
                    <button type="button" class="list-group-item list-group-item-action"
                            onclick="seleccionarProveedor(${p.id}, '${escapeHtml(p.nombre)}')">
                        <strong>${escapeHtml(p.nombre)}</strong>
                    </button>
                `).join('');
            }
            contenedor.style.display = 'block';
        }

        function seleccionarProveedor(id, nombre) {
            proveedorSeleccionado = { id, nombre };
            document.getElementById('idProveedor').value = id;
            document.getElementById('nombreProveedorSeleccionado').textContent = nombre;
            document.getElementById('infoProveedor').classList.remove('d-none');
            document.getElementById('resultadosProveedor').style.display = 'none';
            document.getElementById('buscadorProveedor').value = '';
            document.getElementById('previewProveedor').style.display = 'block';
            document.getElementById('textoProveedorPreview').textContent = nombre;
        }

        function limpiarProveedor() {
            proveedorSeleccionado = null;
            document.getElementById('idProveedor').value = '';
            document.getElementById('infoProveedor').classList.add('d-none');
            document.getElementById('previewProveedor').style.display = 'none';
        }

        function mostrarModalProveedores() {
            new bootstrap.Modal(document.getElementById('modalProveedores')).show();
            cargarProveedoresModal();
        }

        async function cargarProveedoresModal() {
            const tbody = document.getElementById('tbodyProveedoresModal');
            tbody.innerHTML = '<tr><td colspan="3" class="text-center"><div class="spinner-border spinner-border-sm"></div></td></tr>';

            try {
                const response = await fetch('/Productos/BuscarProveedores?texto=a');
                const proveedores = await response.json();
                tbody.innerHTML = proveedores.map(p => `
                    <tr>
                        <td>${p.id}</td>
                        <td>${escapeHtml(p.nombre)}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-info" onclick="seleccionarProveedorDesdeModal(${p.id}, '${escapeHtml(p.nombre)}')">
                                <i class="fas fa-check"></i>
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                tbody.innerHTML = '<tr><td colspan="3" class="text-center text-danger">Error al cargar</td></tr>';
            }
        }

        function seleccionarProveedorDesdeModal(id, nombre) {
            seleccionarProveedor(id, nombre);
            bootstrap.Modal.getInstance(document.getElementById('modalProveedores')).hide();
        }

        function mostrarModalNuevoProveedor() {
            new bootstrap.Modal(document.getElementById('modalNuevoProveedor')).show();
        }

        async function crearProveedorRapido() {
            const nombre = document.getElementById('nuevoProveedorNombre').value.trim();
            const errorDiv = document.getElementById('errorNuevoProveedor');

            if (nombre.length < 2) {
                errorDiv.textContent = 'El nombre debe tener al menos 2 caracteres';
                errorDiv.classList.remove('d-none');
                return;
            }

            try {
                const response = await fetch('/Productos/CrearProveedorRapido', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre })
                });

                const result = await response.json();
                if (!response.ok) throw new Error(result.error);

                seleccionarProveedor(result.id, result.nombre);
                bootstrap.Modal.getInstance(document.getElementById('modalNuevoProveedor')).hide();

            } catch (error) {
                errorDiv.textContent = error.message;
                errorDiv.classList.remove('d-none');
            }
        }

        // ========== CÁLCULOS Y VALIDACIONES ==========
        function calcularMargen() {
            const compra = parseFloat(document.getElementById('precioCompra').value) || 0;
            const venta = parseFloat(document.getElementById('precioVenta').value) || 0;

            if (compra > 0 && venta > 0) {
                const margen = ((venta - compra) / compra) * 100;
                document.getElementById('margenPorcentaje').value = `${margen.toFixed(1)}%`;

                let alertClass = 'alert-danger';
                let mensaje = 'Margen bajo';
                if (margen >= 30) { alertClass = 'alert-success'; mensaje = 'Margen óptimo'; }
                else if (margen >= 20) { alertClass = 'alert-warning'; mensaje = 'Margen aceptable'; }

                document.getElementById('previewMargen').className = `alert ${alertClass} small mb-0`;
                document.getElementById('previewMargen').innerHTML = `<i class="fas fa-calculator me-2"></i>Margen: ${margen.toFixed(1)}%`;
            }
        }

        function actualizarPreview() {
            const nombre = document.getElementById('nombre').value || '@Model.Nombre';
            const codigo = document.getElementById('codigo').value || '@Model.Codigo';
            const precio = parseFloat(document.getElementById('precioVenta').value) || @Model.PrecioVenta;

            document.getElementById('previewNombre').textContent = nombre;
            document.getElementById('previewCodigo').textContent = codigo;
            document.getElementById('previewPrecio').textContent = `S/ ${precio.toFixed(2)}`;
        }

        async function validarCodigoUnico() {
            const codigo = document.getElementById('codigo').value;
            if (!codigo || codigo === '@Model.Codigo') return; // No cambió

            const feedback = document.getElementById('codigoFeedback');
            feedback.innerHTML = '<span class="text-info"><i class="fas fa-spinner fa-spin me-1"></i>Verificando...</span>';

            try {
                const response = await fetch(`/Productos/ValidarCodigo?codigo=${encodeURIComponent(codigo)}&excluirId=${productoId}`);
                const result = await response.json();

                feedback.innerHTML = result.valido
                    ? '<span class="text-success"><i class="fas fa-check-circle me-1"></i>Código disponible</span>'
                    : '<span class="text-danger"><i class="fas fa-times-circle me-1"></i>' + result.mensaje + '</span>';
            } catch (error) {
                feedback.textContent = '';
            }
        }

        // ========== ELIMINAR ==========
        function confirmarEliminar() {
            new bootstrap.Modal(document.getElementById('modalEliminar')).show();
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
                // ========== HISTORIAL DE MOVIMIENTOS ==========
        async function cargarHistorialMovimientos() {
            const tbody = document.getElementById('tbodyHistorial');
            tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-3"><i class="fas fa-spinner fa-spin me-2"></i>Cargando...</td></tr>';

            try {
                const response = await fetch(`/Productos/GetHistorialMovimientos/?id=${productoId}&limite=10`);
                const movimientos = await response.json();

                if (movimientos.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4"><i class="fas fa-inbox fa-2x mb-2 d-block opacity-25"></i>Sin movimientos registrados</td></tr>';
                    return;
                }

                tbody.innerHTML = movimientos.map(m => `
                    <tr>
                        <td class="text-nowrap">${new Date(m.fechaMovimiento).toLocaleString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</td>
                        <td>
                            <span class="${m.tipoMovimientoClass}">
                                <i class="${m.tipoMovimientoIcon} me-1"></i>${m.tipoMovimiento}
                            </span>
                        </td>
                        <td class="text-end ${m.cantidad > 0 ? 'text-success' : 'text-danger'}">
                            ${m.cantidad > 0 ? '+' : ''}${m.cantidad.toFixed(2)}
                        </td>
                        <td class="text-end">${m.stockAnterior.toFixed(2)}</td>
                        <td class="text-end fw-bold">${m.stockNuevo.toFixed(2)}</td>
                        <td class="small">${escapeHtml(m.usuarioNombre)}</td>
                        <td class="small text-truncate" style="max-width: 150px;" title="${escapeHtml(m.observaciones || '-')}">
                            ${escapeHtml(m.observaciones || '-')}
                        </td>
                    </tr>
                `).join('');

            } catch (error) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center text-danger py-3"><i class="fas fa-exclamation-circle me-2"></i>Error al cargar historial</td></tr>';
            }
        }

        // Cargar historial al iniciar
        document.addEventListener('DOMContentLoaded', cargarHistorialMovimientos);

        // ========== AJUSTE DE STOCK ==========
        function mostrarModalAjusteStock() {
            // Resetear modal
            document.getElementById('nuevoStockInput').value = '@Model.StockActual';
            document.getElementById('diferenciaStock').value = '0.000';
            document.getElementById('motivoAjuste').value = '';
            document.getElementById('tipoAjuste').checked = true;
            document.getElementById('alertaAjusteStock').className = 'alert d-none';
            document.getElementById('alertaAjusteStock').textContent = '';

            // Calcular diferencia inicial
            calcularDiferenciaStock();

            new bootstrap.Modal(document.getElementById('modalAjusteStock')).show();
        }

        // Calcular diferencia cuando cambia el nuevo stock
        document.getElementById('nuevoStockInput')?.addEventListener('input', calcularDiferenciaStock);

        function calcularDiferenciaStock() {
            const stockAnterior = parseFloat(document.getElementById('ajusteStockAnterior').value);
            const nuevoStock = parseFloat(document.getElementById('nuevoStockInput').value) || 0;
            const diferencia = nuevoStock - stockAnterior;

            const inputDiferencia = document.getElementById('diferenciaStock');
            inputDiferencia.value = (diferencia >= 0 ? '+' : '') + diferencia.toFixed(3);

            // Colorear según el tipo
            if (diferencia > 0) {
                inputDiferencia.className = 'form-control text-success fw-bold';
            } else if (diferencia < 0) {
                inputDiferencia.className = 'form-control text-danger fw-bold';
            } else {
                inputDiferencia.className = 'form-control text-muted fw-bold';
            }

            // Auto-seleccionar tipo de movimiento
            if (diferencia > 0) {
                document.getElementById('tipoEntrada').checked = true;
            } else if (diferencia < 0) {
                document.getElementById('tipoSalida').checked = true;
            } else {
                document.getElementById('tipoAjuste').checked = true;
            }
        }

        async function confirmarAjusteStock() {
            const btn = document.getElementById('btnConfirmarAjuste');
            const alerta = document.getElementById('alertaAjusteStock');

            // Validaciones
            const nuevoStock = parseFloat(document.getElementById('nuevoStockInput').value);
            const stockAnterior = parseFloat(document.getElementById('ajusteStockAnterior').value);
            const motivo = document.getElementById('motivoAjuste').value.trim();
            const tipoMovimiento = document.querySelector('input[name="tipoMovimiento"]:checked').value;

            if (isNaN(nuevoStock) || nuevoStock < 0) {
                mostrarAlertaAjuste('El stock no puede ser negativo', 'danger');
                return;
            }

            if (motivo.length < 5) {
                mostrarAlertaAjuste('El motivo debe tener al menos 5 caracteres', 'danger');
                return;
            }

            // Deshabilitar botón
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Procesando...';

            try {

                let jsonBody = JSON.stringify({
                        ProductoId: productoId,
                        NuevoStock: nuevoStock,
                        StockAnterior: stockAnterior,
                        TipoMovimiento: tipoMovimiento,
                        Motivo: motivo
                    });
                const response = await fetch('/Productos/AjustarStock', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: jsonBody
                });

                const resultado = await response.json();

                if (resultado.success) {
                    mostrarAlertaAjuste(`Stock ajustado correctamente. Nuevo stock: ${resultado.stockNuevo.toFixed(3)}`, 'success');

                    // Actualizar valores en la página
                    setTimeout(() => {
                        // Actualizar stock en preview
                        document.getElementById('previewStock').textContent = `${resultado.stockNuevo.toFixed(3)} @Model.UnidadMedidaAbreviatura`;
                        document.getElementById('displayStockActual').textContent = resultado.stockNuevo.toFixed(3);
                        document.getElementById('ajusteStockAnterior').value = resultado.stockNuevo;

                        // Recargar historial
                        cargarHistorialMovimientos();

                        // Cerrar modal después de 1.5 segundos
                        setTimeout(() => {
                            bootstrap.Modal.getInstance(document.getElementById('modalAjusteStock')).hide();
                            location.reload(); // Recargar para actualizar todo
                        }, 1500);
                    }, 500);

                } else {
                    mostrarAlertaAjuste(resultado.message || 'Error al ajustar stock', 'danger');
                    if (resultado.stockAnterior) {
                        document.getElementById('ajusteStockAnterior').value = resultado.stockAnterior;
                        document.getElementById('displayStockActual').textContent = resultado.stockAnterior.toFixed(3);
                    }
                }

            } catch (error) {
                mostrarAlertaAjuste('Error de conexión. Intente nuevamente.', 'danger');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check me-2"></i>Confirmar Ajuste';
            }
        }

        function mostrarAlertaAjuste(mensaje, tipo) {
            const alerta = document.getElementById('alertaAjusteStock');
            alerta.className = `alert alert-${tipo}`;
            alerta.innerHTML = `<i class="fas fa-${tipo === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>${mensaje}`;
        }
        // Validación Bootstrap
        (function () {
            'use strict';
            var forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
}