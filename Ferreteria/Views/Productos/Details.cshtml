@using Ferreteria.DTOs
@model Ferreteria.DTOs.ProductoDetailDto
@{
    ViewData["Title"] = "Detalle del Producto";
    var historial = ViewBag.HistorialMovimientos as IEnumerable<MovimientoInventarioDto> ?? new List<MovimientoInventarioDto>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        
        <h2 class="mb-0">Detalle completo del producto @Model.Nombre</h2>
         
    </div>
    <div class="d-flex gap-2">
         
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        @* Info General *@
        <div class="card mb-4">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-info-circle me-2 text-primary"></i>Información General</h5>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted">Código</label>
                        <p class="fw-bold fs-5">@Model.Codigo</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted">Estado</label>
                        <p>
                            <span class="badge @(Model.Activo ? "bg-success" : "bg-secondary") fs-6">
                                @(Model.Activo ? "Activo" : "Inactivo")
                            </span>
                            @if (Model.StockBajo)
                            {
                                <span class="badge bg-warning text-dark ms-2">Stock Bajo</span>
                            }
                        </p>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted">Nombre</label>
                        <p class="fs-5">@Model.Nombre</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted">Descripción</label>
                        <p class="border rounded p-3 bg-light">@(Model.Descripcion ?? "Sin descripción")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted">Categoría</label>
                        <p>
                            <span class="badge bg-secondary fs-6">
                                <i class="fas fa-tag me-1"></i>@(Model.CategoriaNombre ?? "Sin categoría")
                            </span>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted">Unidad de Medida</label>
                        <p>
                            <span class="badge bg-primary fs-6">
                                <i class="fas fa-ruler me-1"></i>@Model.UnidadMedidaNombre (@Model.UnidadMedidaAbreviatura)
                            </span>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        @* Precios y Stock *@
        <div class="card mb-4">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-dollar-sign me-2 text-success"></i>Precios y Stock</h5>
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <div class="col-md-4 text-center border-end">
                        <label class="form-label text-muted">Precio de Compra</label>
                        <p class="fs-4 text-dark">S/ @Model.PrecioCompra.ToString("N2")</p>
                    </div>
                    <div class="col-md-4 text-center border-end">
                        <label class="form-label text-muted">Precio de Venta</label>
                        <p class="fs-4 text-primary fw-bold">S/ @Model.PrecioVenta.ToString("N2")</p>
                    </div>
                    <div class="col-md-4 text-center">
                        <label class="form-label text-muted">Margen de Ganancia</label>
                        <p class="fs-4 @(Model.MargenGanancia >= 30 ? "text-success" : Model.MargenGanancia >= 20 ? "text-warning" : "text-danger")">
                            @Model.MargenGanancia.ToString("N1")%
                        </p>
                    </div>
                </div>

                <hr class="my-4">

                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="alert @(Model.StockBajo ? "alert-danger" : "alert-success")">
                            <label class="form-label text-muted mb-1">Stock Actual</label>
                            <p class="fs-4 fw-bold mb-0">@Model.StockActual.ToString("N2") @Model.UnidadMedidaAbreviatura</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="alert alert-info">
                            <label class="form-label text-muted mb-1">Stock Mínimo</label>
                            <p class="fs-5 fw-bold mb-0">@Model.StockMinimo.ToString("N2") @Model.UnidadMedidaAbreviatura</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="alert alert-warning">
                            <label class="form-label text-muted mb-1">Valor en Inventario</label>
                            <p class="fs-5 fw-bold mb-0">S/ @Model.ValorInventario.ToString("N2")</p>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.UbicacionAlmacen))
                {
                    <div class="mt-3">
                        <label class="form-label text-muted"><i class="fas fa-map-marker-alt me-2"></i>Ubicación en Almacén</label>
                        <p class="border rounded p-2">@Model.UbicacionAlmacen</p>
                    </div>
                }
            </div>
        </div>

        @* Proveedor *@
        @if (Model.IdProveedor.HasValue)
        {
            <div class="card mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0"><i class="fas fa-truck me-2 text-info"></i>Proveedor</h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-info bg-opacity-10 rounded p-3 me-3">
                            <i class="fas fa-building fa-2x text-info"></i>
                        </div>
                        <div>
                            <h6 class="mb-1">@Model.ProveedorNombre</h6>
                            <span class="badge bg-info">ID: @Model.IdProveedor</span>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Historial de Movimientos *@
        <div class="card">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-history me-2 text-secondary"></i>Historial de Movimientos</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th class="text-end">Cantidad</th>
                                <th class="text-end">Stock Ant.</th>
                                <th class="text-end">Stock Nuevo</th>
                                <th>Usuario</th>
                                <th>Observación</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!historial.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">
                                        <i class="fas fa-inbox fa-2x mb-2 d-block opacity-25"></i>
                                        Sin movimientos registrados
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var m in historial)
                                {
                                    <tr>
                                        <td class="text-nowrap">@m.FechaMovimiento.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <span class="@m.TipoMovimientoClass">
                                                <i class="@m.TipoMovimientoIcon me-1"></i>@m.TipoMovimiento
                                            </span>
                                        </td>
                                        <td class="text-end @(m.Cantidad > 0 ? "text-success" : "text-danger")">
                                            @(m.Cantidad > 0 ? "+" : "")@m.Cantidad.ToString("N2")
                                        </td>
                                        <td class="text-end">@m.StockAnterior.ToString("N2")</td>
                                        <td class="text-end fw-bold">@m.StockNuevo.ToString("N2")</td>
                                        <td class="small">@m.UsuarioNombre</td>
                                        <td class="small" title="@m.Observaciones">@(m.Observaciones?.Length > 30 ? m.Observaciones.Substring(0, 30) + "..." : m.Observaciones)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @* Sidebar *@
    <div class="col-lg-4">
        <div class="card sticky-top" style="top: 20px;">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-cogs me-2 text-warning"></i>Acciones</h5>
            </div>
            <div class="card-body p-4">
                <div class="d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-lg">
                        <i class="fas fa-edit me-2"></i>Editar Producto
                    </a>
                     
                    
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Información del Sistema</h6>
            </div>
            <div class="card-body p-4">
                <ul class="list-unstyled mb-0 small">
                    <li class="mb-2">
                        <span class="text-muted">ID Interno:</span>
                        <strong class="float-end">@Model.Id</strong>
                    </li>
                    <li class="mb-2">
                        <span class="text-muted">Creado el:</span>
                        <strong class="float-end">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</strong>
                    </li>
                    <li class="mb-2">
                        <span class="text-muted">Creado por:</span>
                        <strong class="float-end">@(Model.UsuarioCreacion ?? "Sistema")</strong>
                    </li>
                    <li>
                        <span class="text-muted">Estado:</span>
                        <span class="badge @(Model.Activo ? "bg-success" : "bg-secondary") float-end">
                            @(Model.Activo ? "Activo" : "Inactivo")
                        </span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>