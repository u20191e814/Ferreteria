@using Ferreteria.DTOs
@model Ferreteria.DTOs.ProductoCreateDto
@{
    ViewData["Title"] = "Nuevo Producto";
    var unidades = ViewBag.UnidadesMedida as IEnumerable<UnidadMedidaDto> ?? new List<UnidadMedidaDto>();
    var categorias = ViewBag.Categorias as IEnumerable<CategoriaDto> ?? new List<CategoriaDto>();
}

 

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
         
        <h2 class="mb-0">Nuevo Producto</h2>
        <p class="text-muted mb-0">Registra un nuevo producto en el inventario</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Volver al listado
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <form asp-action="Create" method="post" id="formProducto" class="needs-validation" novalidate>
            <div class="card">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0"><i class="fas fa-box me-2 text-primary"></i>Información del Producto</h5>
                </div>
                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        @* Código y Nombre *@
                        <div class="col-md-6">
                            <label asp-for="Codigo" class="form-label fw-bold">
                                Código <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-barcode text-muted"></i>
                                </span>
                                <input asp-for="Codigo" class="form-control" placeholder="PROD-001" required
                                       maxlength="50" id="codigo" onblur="validarCodigo()">
                                <button type="button" class="btn btn-outline-secondary" onclick="generarCodigo()" title="Generar código automático">
                                    <i class="fas fa-magic"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Codigo" class="text-danger small"></span>
                            <div id="codigoFeedback" class="form-text"></div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label fw-bold">
                                Nombre del Producto <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Cemento Portland Tipo I"
                                   required maxlength="200" id="nombre">
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        @* NUEVO: CATEGORÍA CON BÚSQUEDA E INGRESO DESDE BD *@
                        <div class="col-md-6">
                            <label asp-for="CategoriaId" class="form-label fw-bold">Categoría</label>
                            <input type="hidden" asp-for="CategoriaId" id="categoriaId" />

                            <div class="position-relative">
                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="fas fa-tags text-muted"></i>
                                    </span>
                                    <input type="text" class="form-control" id="buscadorCategoria"
                                           placeholder="Buscar o seleccionar categoría..." autocomplete="off">
                                    <button type="button" class="btn btn-outline-primary" onclick="mostrarModalGestionCategorias()"
                                            title="Gestionar categorías (Editar, Eliminar, Nueva)">
                                        <i class="fas fa-th-large"></i>
                                    </button>
                                </div>

                                @* Indicador de carga *@
                                <div id="indicadorCargaCategoria" class="position-absolute end-0 top-0 mt-2 me-5 d-none">
                                    <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                                </div>
                            </div>

                            <div id="resultadosCategoria" class="list-group shadow-lg position-absolute w-100"
                                 style="z-index: 1000; max-height: 200px; overflow-y: auto; display: none;">
                            </div>

                            @* Info de categoría seleccionada *@
                            <div id="infoCategoria" class="d-none mt-2">
                                <div class="alert alert-primary p-2 mb-0 border-0 categoria-seleccionada">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-tag me-2 text-primary"></i>
                                            <span id="nombreCategoriaSeleccionada" class="fw-bold">-</span>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="limpiarCategoria()" title="Cambiar categoría">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div id="sinCategoria" class="form-text">
                                <i class="fas fa-info-circle me-1"></i>Seleccione una categoría o déjelo vacío
                            </div>
                        </div>
                        @* Unidad de Medida desde BD *@
                        <div class="col-md-6">
                            <label asp-for="UnidadMedidaId" class="form-label fw-bold">
                                Unidad de Medida <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-ruler text-muted"></i>
                                </span>
                                <select asp-for="UnidadMedidaId" class="form-select" required id="unidadMedida">
                                    <option value="">Seleccionar...</option>
                                    @foreach (var um in unidades)
                                    {
                                        <option value="@um.Id" data-abrev="@um.Abreviatura">@um.NombreCompleto</option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="UnidadMedidaId" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3"
                                      placeholder="Descripción detallada del producto, características, usos..."
                                      maxlength="500" id="descripcion"></textarea>
                            <div class="form-text d-flex justify-content-between">
                                <span>Información adicional para el catálogo</span>
                                <span id="contadorDesc">0/500</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Card Precios y Stock *@
            <div class="card mt-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0"><i class="fas fa-dollar-sign me-2 text-success"></i>Precios y Stock</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="PrecioCompra" class="form-label fw-bold">
                                Precio de Compra <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">S/</span>
                                <input asp-for="PrecioCompra" type="number" class="form-control"
                                       placeholder="0.00" step="1" min="0" required id="precioCompra"
                                       onchange="calcularMargen()">
                            </div>
                            <span asp-validation-for="PrecioCompra" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="PrecioVenta" class="form-label fw-bold">
                                Precio de Venta <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">S/</span>
                                <input asp-for="PrecioVenta" type="number" class="form-control"
                                       placeholder="0.00" step="1" min="0" required id="precioVenta"
                                       onchange="calcularMargen()">
                            </div>
                            <span asp-validation-for="PrecioVenta" class="text-danger small"></span>
                            <div id="margenGanancia" class="form-text"></div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Margen de Ganancia</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-percentage text-muted"></i></span>
                                <input type="text" class="form-control" id="margenPorcentaje" readonly placeholder="0%">
                            </div>
                            <div id="margenAlert" class="form-text"></div>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="StockInicial" class="form-label fw-bold">
                                Stock Inicial <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input asp-for="StockInicial" type="number" class="form-control"
                                       placeholder="0" step="1" min="0" required id="stockInicial">
                                <span class="input-group-text bg-light" id="abreviaturaStock">und</span>
                            </div>
                            <span asp-validation-for="StockInicial" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="StockMinimo" class="form-label fw-bold">
                                Stock Mínimo <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <input asp-for="StockMinimo" type="number" class="form-control"
                                       placeholder="0" step="1" min="0" required id="stockMinimo">
                                <span class="input-group-text bg-light" id="abreviaturaMinimo">und</span>
                            </div>
                            <span asp-validation-for="StockMinimo" class="text-danger small"></span>
                            <div class="form-text">Cantidad mínima antes de alerta de stock bajo</div>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="UbicacionAlmacen" class="form-label fw-bold">Ubicación en Almacén</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-map-marker-alt text-muted"></i>
                                </span>
                                <input asp-for="UbicacionAlmacen" class="form-control"
                                       placeholder="Ej: Estante A-12" maxlength="100">
                            </div>
                            <span asp-validation-for="UbicacionAlmacen" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            @* Card Proveedor *@
            <div class="card mt-4">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-truck me-2 text-info"></i>Información de Proveedor</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="mostrarModalProveedores()">
                        <i class="fas fa-list me-1"></i>Ver Todos
                    </button>
                </div>
                <div class="card-body p-4">
                    <input type="hidden" asp-for="idProveedor" id="idProveedor" />
                    
                    <div class="position-relative">
                        <label class="form-label fw-bold">Buscar Proveedor</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-building text-muted"></i>
                            </span>
                            <input type="text" class="form-control" id="buscadorProveedor"
                                   placeholder="Escriba nombre del proveedor para buscar..."
                                   autocomplete="off">
                            <button type="button" class="btn btn-outline-success" onclick="mostrarModalNuevoProveedor()" title="Nuevo proveedor rápido">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                        <div class="form-text">Mínimo 2 caracteres para buscar en la base de datos</div>

                        <div id="indicadorCargaProveedor" class="position-absolute end-0 top-50 mt-4 me-5 d-none">
                            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                        </div>
                    </div>

                    <div id="resultadosProveedor" class="list-group shadow-lg position-absolute w-100"
                         style="z-index: 1000; max-height: 300px; overflow-y: auto; display: none; margin-top: -10px;">
                    </div>

                    <div id="infoProveedor" class="d-none mt-3">
                        <div class="alert alert-info p-3 mb-0 border-0 proveedor-seleccionado">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 fw-bold" id="nombreProveedorSeleccionado">-</h6>
                                    <span class="badge bg-primary">Proveedor seleccionado</span>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="limpiarProveedor()" title="Cambiar proveedor">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div id="sinProveedor" class="text-center py-3 text-muted border rounded bg-light mt-3">
                        <i class="fas fa-building fa-2x mb-2 opacity-25"></i>
                        <p class="mb-0">Ningún proveedor seleccionado. Busque o cree uno nuevo.</p>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <button type="reset" class="btn btn-outline-secondary btn-lg" onclick="limpiarFormulario()">
                    <i class="fas fa-undo me-2"></i>Limpiar
                </button>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-lg" id="btnGuardar">
                        <i class="fas fa-save me-2"></i>Guardar Producto
                    </button>
                    <button type="submit" class="btn btn-success btn-lg" name="guardarYNuevo" value="true" id="btnGuardarYNuevo">
                        <i class="fas fa-plus me-2"></i>Guardar y Nuevo
                    </button>
                </div>
            </div>
        </form>
    </div>

    @* Columna Preview *@
    <div class="col-lg-4">
        <div class="card sticky-top" style="top: 20px; z-index: 100;">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-eye me-2 text-warning"></i>Vista Previa</h5>
            </div>
            <div class="card-body p-4">
                <div class="text-center mb-3">
                    <div class="bg-light rounded p-4 mb-3" style="height: 150px; display: flex; align-items: center; justify-content: center;">
                        <i class="fas fa-box-open fa-3x text-muted opacity-25" id="previewIcon"></i>
                    </div>
                </div>

                <h5 class="mb-1" id="previewNombre">Nombre del Producto</h5>
                <p class="text-muted small mb-2" id="previewCodigo">PROD-000</p>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge bg-secondary" id="previewCategoria">Sin categoría</span>
                    <span class="badge bg-primary" id="previewUnidad">und</span>
                </div>

                <hr>

                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <small class="text-muted d-block">Precio Venta</small>
                        <strong class="text-primary fs-5" id="previewPrecio">S/ 0.00</strong>
                    </div>
                    <div class="col-6 text-end">
                        <small class="text-muted d-block">Stock</small>
                        <strong class="text-success" id="previewStock">0 und</strong>
                    </div>
                </div>

                <div class="alert alert-info small mb-0" id="previewMargen">
                    <i class="fas fa-calculator me-2"></i>Margen: 0%
                </div>

                @* Info de proveedor en preview *@
                <div class="mt-3 pt-3 border-top d-none" id="previewProveedor">
                    <small class="text-muted d-block mb-1">Proveedor</small>
                    <span class="badge bg-info text-dark" id="previewNombreProveedor">
                        <i class="fas fa-truck me-1"></i><span id="textoProveedorPreview">-</span>
                    </span>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h6 class="mb-0"><i class="fas fa-lightbulb me-2 text-warning"></i>Consejos</h6>
            </div>
            <div class="card-body p-4">
                <ul class="list-unstyled mb-0 small">
                    <li class="mb-2">
                        <i class="fas fa-check-circle text-success me-2"></i>
                        Use códigos únicos y descriptivos
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-check-circle text-success me-2"></i>
                        El margen recomendado es 30-50%
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-check-circle text-success me-2"></i>
                        Stock mínimo = 10-20% del stock mensual promedio
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-check-circle text-success me-2"></i>
                        Incluya la ubicación exacta para facilitar búsquedas
                    </li>
                    <li>
                        <i class="fas fa-check-circle text-success me-2"></i>
                        La descripción ayuda en las búsquedas del catálogo
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@* ==================== MODALES ==================== *@
@* MODAL DE GESTIÓN COMPLETA DE CATEGORÍAS *@
<div class="modal fade" id="modalGestionCategorias" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-tags me-2"></i>Gestionar Categorías
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @* Toolbar *@
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="input-group w-50">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" class="form-control" id="busquedaGestionCategoria"
                               placeholder="Buscar categoría..." onkeyup="filtrarCategoriasGestion()">
                    </div>
                    <button type="button" class="btn btn-success" onclick="mostrarModalNuevaCategoriaDesdeGestion()">
                        <i class="fas fa-plus me-2"></i>Nueva Categoría
                    </button>
                </div>

                @* Loading *@
                <div id="cargaGestionCategorias" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Cargando categorías...</p>
                </div>

                @* Grid de Categorías *@
                <div id="gridGestionCategorias" class="d-none">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40%">Nombre</th>
                                    <th style="width: 35%">Descripción</th>
                                    <th style="width: 10%" class="text-center">Productos</th>
                                    <th style="width: 15%" class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyGestionCategorias">
                                @* Se carga dinámicamente *@
                            </tbody>
                        </table>
                    </div>
                </div>

                @* Sin resultados *@
                <div id="sinResultadosGestionCategorias" class="text-center py-4 text-muted d-none">
                    <i class="fas fa-search fa-2x mb-2 opacity-25"></i>
                    <p>No se encontraron categorías</p>
                </div>

                @* Estado vacío *@
                <div id="estadoVacioGestionCategorias" class="text-center py-4 text-muted d-none">
                    <i class="fas fa-folder-open fa-2x mb-2 opacity-25"></i>
                    <p>No hay categorías registradas</p>
                    <button class="btn btn-sm btn-outline-primary" onclick="mostrarModalNuevaCategoriaDesdeGestion()">
                        Crear la primera categoría
                    </button>
                </div>
            </div>
             
        </div>
    </div>
</div>

@* MODAL EDITAR CATEGORÍA *@
<div class="modal fade" id="modalEditarCategoria" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">
                    <i class="fas fa-edit me-2"></i>Editar Categoría
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editarCategoriaId" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Nombre <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="editarCategoriaNombre" maxlength="100">
                    <div class="form-text">Mínimo 2 caracteres</div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Descripción</label>
                    <textarea class="form-control" id="editarCategoriaDescripcion" rows="2" maxlength="255"></textarea>
                </div>

                <div id="errorEditarCategoria" class="alert alert-danger d-none"></div>
            </div>
            <div class="modal-footer">
                
                <button type="button" class="btn btn-warning" onclick="guardarEdicionCategoria()">
                    <i class="fas fa-save me-2"></i>Guardar Cambios
                </button>
            </div>
        </div>
    </div>
</div>

@* MODAL CONFIRMAR ELIMINACIÓN *@
<div class="modal fade" id="modalEliminarCategoria" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="eliminarCategoriaId" />

                <div class="text-center mb-3">
                    <i class="fas fa-trash-alt fa-3x text-danger opacity-50"></i>
                </div>

                <p class="text-center">
                    ¿Está seguro de que desea eliminar la categoría <strong id="eliminarCategoriaNombre"></strong>?
                </p>

                <div id="alertaProductosAsociados" class="alert alert-warning d-none">
                    <i class="fas fa-info-circle me-2"></i>
                    Esta categoría tiene <strong id="cantidadProductosEliminar">0</strong> producto(s) asociado(s).
                    No se puede eliminar hasta que reasigne o elimine esos productos.
                </div>

                <div id="errorEliminarCategoria" class="alert alert-danger d-none"></div>
            </div>
            <div class="modal-footer">
                 
                <button type="button" class="btn btn-danger" id="btnConfirmarEliminar" onclick="confirmarEliminarCategoria()">
                    <i class="fas fa-trash me-2"></i>Sí, Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

@* MODAL NUEVA CATEGORÍA (Actualizado para integración) *@
<div class="modal fade" id="modalNuevaCategoria" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Nueva Categoría</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Nombre <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="nuevaCategoriaNombre"
                           placeholder="Ej: Materiales de Construcción" maxlength="100">
                    <div class="form-text">Mínimo 2 caracteres</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Descripción (opcional)</label>
                    <textarea class="form-control" id="nuevaCategoriaDescripcion" rows="2"
                              placeholder="Breve descripción..." maxlength="255"></textarea>
                </div>
                <div id="errorNuevaCategoria" class="alert alert-danger d-none"></div>
            </div>
            <div class="modal-footer">
                
                <button type="button" class="btn btn-success" onclick="crearCategoriaRapida()">
                    <i class="fas fa-save me-2"></i>Crear y Seleccionar
                </button>
            </div>
        </div>
    </div>
</div>
 
