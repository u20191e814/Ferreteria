@using Ferreteria.DTOs
@model PedidoDetailDto
@{
    ViewData["Title"] = $"Pedido {Model.NumeroPedido}";
    var estadosSiguientes = new Dictionary<string, (string nombre, string clase, string icono)>
    {
        ["INICIO"] = ("Iniciar Proceso", "info", "fa-play"),
        ["PROCESO"] = ("Finalizar", "success", "fa-check"),
    };
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
       
        <h2 class="mb-0">
            Pedido @Model.NumeroPedido
            <span class="@Model.EstadoClass ms-2">@Model.Estado</span>
        </h2>
        <p class="text-muted mb-0">
            <i class="fas fa-user me-1"></i>@Model.UsuarioCreacion |
            <i class="fas fa-calendar me-1"></i>@Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver
        </a>
        @if (Model.PuedeAgregarProductos)
        {
            <button type="button" class="btn btn-primary" onclick="mostrarModalAgregarProductos()">
                <i class="fas fa-plus me-2"></i>Agregar Productos
            </button>
        }
    </div>
</div>

<div class="row g-4">
    <!-- Columna Izquierda: Info General -->
    <div class="col-lg-4">
        <!-- Cliente -->
        <div class="card mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-user me-2 text-primary"></i>Cliente</h5>
            </div>
            <div class="card-body">
                <h6>@Model.ClienteNombre</h6>
                <p class="text-muted mb-1"><i class="fas fa-id-card me-2"></i>@Model.ClienteDocumento</p>
                @if (!string.IsNullOrEmpty(Model.ClienteTelefono))
                {
                    <p class="text-muted mb-1"><i class="fas fa-phone me-2"></i>@Model.ClienteTelefono</p>
                }
                @if (!string.IsNullOrEmpty(Model.ClienteDireccion))
                {
                    <p class="text-muted mb-0"><i class="fas fa-map-marker-alt me-2"></i>@Model.ClienteDireccion</p>
                }
            </div>
        </div>

        <!-- Totales -->
        <div class="card mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-calculator me-2 text-success"></i>Resumen</h5>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>SubTotal:</span>
                    <span>S/ @Model.SubTotal.ToString("N2")</span>
                </div>
                
                @if (Model.Descuento > 0)
                {
                    <div class="d-flex justify-content-between mb-2 text-danger">
                        <span>Descuento:</span>
                        <span>-S/ @Model.Descuento.ToString("N2")</span>
                    </div>
                }
                <hr />
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total:</span>
                    <span class="text-primary">S/ @Model.Total.ToString("N2")</span>
                </div>
            </div>
        </div>

        <!-- Cambiar Estado -->
        @if (Model.Estado != "FINALIZADO" && Model.Estado != "CANCELADO")
        {
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-exchange-alt me-2 text-warning"></i>Cambiar Estado</h5>
                </div>
                <div class="card-body">
                    <form asp-action="CambiarEstado" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label">Nuevo Estado</label>
                            <select name="nuevoEstado" class="form-select" id="selectNuevoEstado">
                                @if (Model.Estado == "INICIO")
                                {
                                    <option value="PROCESO">Iniciar Proceso</option>
                                    <option value="CANCELADO">Cancelar Pedido</option>
                                }
                                else if (Model.Estado == "PROCESO")
                                {
                                    <option value="FINALIZADO">Finalizar Pedido</option>
                                    <option value="CANCELADO">Cancelar Pedido</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Observación (opcional)</label>
                            <textarea name="observacion" class="form-control" rows="2"
                                  placeholder="Motivo del cambio..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-warning w-100">
                            <i class="fas fa-save me-2"></i>Aplicar Cambio
                        </button>
                    </form>
                </div>
            </div>
        }

        <!-- Info Adicional -->
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-info-circle me-2 text-info"></i>Información</h5>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Fecha Est. Entrega:</strong></p>
                <p class="text-muted">@(Model.FechaEstimadaEntrega?.ToString("dd/MM/yyyy") ?? "No especificada")</p>

                @if (!string.IsNullOrEmpty(Model.Observaciones))
                {
                    <p class="mb-1"><strong>Observaciones:</strong></p>
                    <p class="text-muted">@Model.Observaciones</p>
                }

                @if (Model.FechaFinalizacion.HasValue)
                {
                    <p class="mb-1"><strong>Finalizado:</strong></p>
                    <p class="text-muted">@Model.FechaFinalizacion.Value.ToString("dd/MM/yyyy HH:mm")</p>
                }
            </div>
        </div>
    </div>

    <!-- Columna Derecha: Detalles -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-boxes me-2 text-primary"></i>Productos</h5>
                <span class="badge bg-primary">@Model.Detalles.Count items</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Código</th>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">P. Unit.</th>
                                <th class="text-end">Desc.</th>
                                <th class="text-end">SubTotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var det in Model.Detalles)
                            {
                                <tr>
                                    <td><code>@det.ProductoCodigo</code></td>
                                    <td>
                                        @det.ProductoNombre
                                        <div class="small text-muted">@det.UnidadMedida</div>
                                    </td>
                                    <td class="text-center">
                                        @det.Cantidad.ToString("N2")
                                    </td>
                                    <td class="text-end">S/ @det.PrecioUnitario.ToString("N2")</td>
                                    <td class="text-end">
                                        @(det.Descuento > 0 ? $"S/ {det.Descuento:N2}" : "-")
                                    </td>
                                    <td class="text-end fw-bold">S/ @det.SubTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-group-divider">
                            <tr class="fw-bold">
                                <td colspan="5" class="text-end">Total:</td>
                                <td class="text-end text-primary fs-5">S/ @Model.Total.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Acciones según estado -->
        <!-- Acciones según estado -->
        @if (Model.Estado == "FINALIZADO")
        {
            <div class="card mt-4 border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-check-circle me-2"></i>Pedido Finalizado</h5>
                </div>
                <div class="card-body">
                    <p>Este pedido está listo para ser convertido en venta.</p>

                    <div id="alertaVentaExistente" class="alert alert-warning d-none">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Este pedido ya tiene una venta asociada.
                        <a href="#" id="linkVerVenta" class="alert-link">Ver venta</a>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-success" onclick="mostrarModalConvertirVenta()" id="btnConvertirVenta">
                            <i class="fas fa-cash-register me-2"></i>Convertir a Venta
                        </button>
                         
                    </div>
                </div>
            </div>
        }
        else if (Model.Estado == "CANCELADO")
        {
            <div class="alert alert-danger mt-4">
                <i class="fas fa-times-circle me-2"></i>
                Este pedido fue cancelado el @(Model.FechaFinalizacion?.ToString("dd/MM/yyyy") ?? "fecha no registrada").
            </div>
        }
    </div>
</div>

<!-- Modal: Agregar Productos -->
<div class="modal fade" id="modalAgregarProductos" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-plus me-2"></i>Agregar Productos al Pedido</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Buscador -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Buscar Producto</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" class="form-control" id="buscadorProducto"
                               placeholder="Escriba código o nombre del producto..." autocomplete="off">
                        <button class="btn btn-outline-primary" type="button" onclick="buscarProducto()">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                    <div class="form-text">Mínimo 2 caracteres para buscar</div>
                </div>

                <!-- Resultados de búsqueda -->
                <div id="resultadosBusqueda" class="list-group mb-3" style="max-height: 200px; overflow-y: auto;">
                    <!-- Se llena dinámicamente -->
                </div>

                <!-- Productos seleccionados -->
                <h6 class="fw-bold mb-3">Productos a Agregar</h6>
                <div id="productosSeleccionados" class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th style="width: 120px;">Cantidad</th>
                                <th style="width: 150px;">P. Unit.</th>
                                <th style="width: 100px;">Desc.</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="tbodyProductosSeleccionados">
                            <!-- Filas dinámicas -->
                        </tbody>
                    </table>
                </div>
                <div id="sinProductos" class="text-center text-muted py-3">
                    <i class="fas fa-box-open fa-2x mb-2 opacity-25"></i>
                    <p class="mb-0">Busque y seleccione productos para agregar</p>
                </div>
            </div>
            <div class="modal-footer">
                <form id="formAgregarProductos" asp-action="AgregarProductos" method="post" class="w-100">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div id="inputsDetalles">
                        <!-- Inputs hidden para los detalles -->
                    </div>

                    <div class="d-flex justify-content-between w-100">
                         
                        <button type="submit" class="btn btn-primary" id="btnConfirmarAgregar" disabled>
                            <i class="fas fa-save me-2"></i>
                            Agregar <span id="contadorProductos">0</span> Producto(s)
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<!-- Modal: Convertir a Venta -->
<div class="modal fade" id="modalConvertirVenta" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-cash-register me-2"></i>Convertir Pedido a Venta</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ConvertirAVenta" method="post" id="formConvertirVenta">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="ClienteId" value="@Model.ClienteId" />
                <div class="modal-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Se generará una venta con los productos de este pedido. El stock será descontado automáticamente.
                    </div>

                    <!-- Tipo de Comprobante -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Tipo de Comprobante <span class="text-danger">*</span></label>
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="TipoComprobante" id="tipoProforma" value="PROFORMA" checked>
                                <label class="btn btn-outline-primary" for="tipoProforma">
                                    <i class="fas fa-file-invoice me-2"></i>Proforma
                                </label>

                                <input type="radio" class="btn-check" name="TipoComprobante" id="tipoBoleta" value="BOLETA" >
                                <label class="btn btn-outline-primary" for="tipoBoleta">
                                    <i class="fas fa-receipt me-2"></i>Boleta
                                </label>

                                <input type="radio" class="btn-check" name="TipoComprobante" id="tipoFactura" value="FACTURA">
                                <label class="btn btn-outline-primary" for="tipoFactura">
                                    <i class="fas fa-file-invoice me-2"></i>Factura
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Fecha de Emisión</label>
                            <input type="date" name="FechaEmision" class="form-control"
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                        </div>

                        <div class="mb-4">
                            <label for="MetodoPago" class="form-label fw-bold">Método de Pago</label>
                            <select name="MetodoPago" class="form-select form-select-lg" required>
                                <option value="EFECTIVO">💵 Efectivo</option>
                                <option value="TARJETA">💳 Tarjeta</option>
                                <option value="TRANSFERENCIA">🏦 Transferencia</option>
                                <option value="YAPE">📱 Yape</option>
                                <option value="PLIN">📲 Plin</option>
                            </select>
                        </div>
                    </div>
                   
                    <!-- Resumen del Pedido -->
                    <div class="card bg-light mb-3">
                        <div class="card-body">
                            <h6 class="fw-bold mb-3">Resumen del Pedido</h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <p class="mb-1"><strong>Cliente:</strong> @Model.ClienteNombre</p>
                                    <p class="mb-1"><strong>Documento:</strong> @Model.ClienteDocumento</p>
                                </div>
                                <div class="col-md-6 text-md-end">
                                    <p class="mb-1"><strong>SubTotal:</strong> <span id="subtotalModal">S/ @Model.SubTotal.ToString("N2")</span></p>
                                    <p class="mb-1"><strong>IGV (18%):</strong> <span id="igvModal">S/ @Model.Impuestos.ToString("N2")</span></p>
                                    <p class="mb-0 fs-5 text-primary"><strong>Total:</strong> <span id="totalModal">S/ @Model.Total.ToString("N2")</span></p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Productos a facturar -->
                    <h6 class="fw-bold mb-3">Productos a Facturar (@Model.Detalles.Count items)</h6>
                    <div class="table-responsive" style="max-height: 250px; overflow-y: auto;">
                        <table class="table table-sm table-hover">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-center">Cant.</th>
                                    <th class="text-end">P. Unit.</th>
                                    <th class="text-end">SubTotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var det in Model.Detalles)
                                {
                                    <tr>
                                        <td>
                                            <small class="text-muted">@det.ProductoCodigo</small><br>
                                            @det.ProductoNombre
                                        </td>
                                        <td class="text-center">@det.Cantidad.ToString("N2")</td>
                                        <td class="text-end">S/ @det.PrecioUnitario.ToString("N2")</td>
                                        <td class="text-end fw-bold">S/ @det.SubTotal.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-group-divider">
                                <tr class="fw-bold">
                                    <td colspan="3" class="text-end">TOTAL:</td>
                                    <td class="text-end text-primary fs-5"><span id="totalFooter">S/ @Model.Total.ToString("N2")</span></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <!-- Observaciones -->
                    <div class="mt-3">
                        <label class="form-label">Observaciones (opcional)</label>
                        <textarea name="Observaciones" class="form-control" rows="2"
                                  placeholder="Notas adicionales para la venta..."></textarea>
                    </div>

                    <div id="errorConvertirVenta" class="alert alert-danger mt-3 d-none"></div>
                </div>
                <div class="modal-footer">
                     
                    <button type="submit" class="btn btn-success btn-lg" id="btnConfirmarVenta">
                        <i class="fas fa-check-circle me-2"></i>
                        Confirmar y Generar Venta
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        let productosEnLista = [];
        let productoBuscado = null;

        function mostrarModalAgregarProductos() {
            productosEnLista = [];
            actualizarTablaProductos();
            document.getElementById('buscadorProducto').value = '';
            document.getElementById('resultadosBusqueda').innerHTML = '';
            new bootstrap.Modal(document.getElementById('modalAgregarProductos')).show();
        }

        async function buscarProducto() {
            const termino = document.getElementById('buscadorProducto').value.trim();
            if (termino.length < 2) return;

            const resultados = document.getElementById('resultadosBusqueda');
            resultados.innerHTML = '<div class="text-center py-2"><span class="spinner-border spinner-border-sm"></span> Buscando...</div>';

            try {
                const response = await fetch(`/Pedidos/BuscarProductos?termino=${encodeURIComponent(termino)}`);
                if (!response.ok) throw new Error('Error en búsqueda');

                const productos = await response.json();

                if (productos.length === 0) {
                    resultados.innerHTML = '<div class="list-group-item text-muted text-center">No se encontraron productos</div>';
                } else {
                    resultados.innerHTML = productos.map(p => `
                        <button type="button" class="list-group-item list-group-item-action"
                                onclick="seleccionarProducto(${p.id}, '${escapeHtml(p.codigo)}', '${escapeHtml(p.nombre)}', ${p.precioVenta}, ${p.stockActual}, '${escapeHtml(p.unidadMedida)}')">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>${escapeHtml(p.codigo)}</strong> - ${escapeHtml(p.nombre)}
                                    <div class="small text-muted">Stock: ${p.stockActual} | Precio: S/ ${p.precioVenta.toFixed(2)}</div>
                                </div>
                                <span class="badge bg-primary">Seleccionar</span>
                            </div>
                        </button>
                    `).join('');
                }
            } catch (error) {
                resultados.innerHTML = '<div class="list-group-item text-danger text-center">Error al buscar</div>';
            }
        }

        function seleccionarProducto(id, codigo, nombre, precio, stock, unidad) {
            // Verificar si ya está en la lista
            if (productosEnLista.some(p => p.productoId === id)) {
                swal("Producto", "Este producto ya está en la lista", "info");
               
                return;
            }

            productosEnLista.push({
                productoId: id,
                codigo: codigo,
                nombre: nombre,
                precioUnitario: precio,
                stock: stock,
                unidad: unidad,
                cantidad: 1,
                descuento: 0
            });

            actualizarTablaProductos();
            document.getElementById('resultadosBusqueda').innerHTML = '';
            document.getElementById('buscadorProducto').value = '';
        }

        function actualizarTablaProductos() {
            const tbody = document.getElementById('tbodyProductosSeleccionados');
            const sinProductos = document.getElementById('sinProductos');
            const btnConfirmar = document.getElementById('btnConfirmarAgregar');
            const contador = document.getElementById('contadorProductos');

            if (productosEnLista.length === 0) {
                tbody.innerHTML = '';
                sinProductos.classList.remove('d-none');
                btnConfirmar.disabled = true;
                contador.textContent = '0';
                document.getElementById('inputsDetalles').innerHTML = '';
                return;
            }

            sinProductos.classList.add('d-none');
            btnConfirmar.disabled = false;
            contador.textContent = productosEnLista.length;

            tbody.innerHTML = productosEnLista.map((p, index) => `
                <tr>
                    <td>
                        <strong>${escapeHtml(p.codigo)}</strong>
                        <div class="small text-muted">${escapeHtml(p.nombre)}</div>
                        <div class="small text-muted">Stock: ${p.stock} ${p.unidad}</div>
                    </td>
                    <td>
                        <input type="number" class="form-control form-control-sm"
                               value="${p.cantidad}" min="0.01" max="${p.stock}" step="0.01"
                               onchange="actualizarCantidad(${index}, this.value)" required>
                    </td>
                    <td>
                        <input type="number" class="form-control form-control-sm"
                               value="${p.precioUnitario.toFixed(2)}" min="0.01" step="0.01"
                               onchange="actualizarPrecio(${index}, this.value)">
                    </td>
                    <td>
                        <input type="number" class="form-control form-control-sm"
                               value="${p.descuento.toFixed(2)}" min="0" step="0.01"
                               onchange="actualizarDescuento(${index}, this.value)">
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="eliminarProducto(${index})">
                            <i class="fas fa-times"></i>
                        </button>
                    </td>
                </tr>
            `).join('');

            // Generar inputs hidden para el form
            document.getElementById('inputsDetalles').innerHTML = productosEnLista.map((p, index) => `
                <input type="hidden" name="detalles[${index}].ProductoId" value="${p.productoId}">
                <input type="hidden" name="detalles[${index}].Cantidad" value="${p.cantidad}">
                <input type="hidden" name="detalles[${index}].PrecioUnitario" value="${p.precioUnitario}">
                <input type="hidden" name="detalles[${index}].Descuento" value="${p.descuento}">
            `).join('');
        }

        function actualizarCantidad(index, valor) {
            const cantidad = parseFloat(valor);
            if (cantidad > productosEnLista[index].stock) {
                swal("Producto", `Stock insuficiente. Máximo disponible: ${productosEnLista[index].stock}`, "info");
                 
                return;
            }
            productosEnLista[index].cantidad = cantidad;
            actualizarTablaProductos();
        }

        function actualizarPrecio(index, valor) {
            productosEnLista[index].precioUnitario = parseFloat(valor);
            actualizarTablaProductos();
        }

        function actualizarDescuento(index, valor) {
            productosEnLista[index].descuento = parseFloat(valor);
            actualizarTablaProductos();
        }

        function eliminarProducto(index) {
            productosEnLista.splice(index, 1);
            actualizarTablaProductos();
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        // Funciones para conversión a venta
        function mostrarModalConvertirVenta() {
            if ("@Model.Estado" == "FINALIZADO") {
                // Validar primero vía AJAX
                fetch(`/Pedidos/ValidarParaVenta?id=@Model.Id`)
                .then(response => response.json())
                .then(data => {
                    if (data.valido) {
                        const modalEl = document.getElementById('modalConvertirVenta');
                        const modal = new bootstrap.Modal(modalEl);
                        modal.show();

                        // Después de mostrar el modal configurar listeners y totales
                        configurarComportamientoComprobante();
                        actualizarTotalesVenta();
                    } else if (data.yaConvertido) {
                        document.getElementById('alertaVentaExistente').classList.remove('d-none');
                        document.getElementById('btnConvertirVenta').disabled = true;
                        document.getElementById('btnConvertirVenta').classList.add('d-none');

                       
                    } else {
                        swal("Pedido", data.error || 'No se puede convertir este pedido', "error");
                        
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    swal("Pedido",'Error al validar el pedido', "error");
                     
                });
            }
            
        }

        // Configura los listeners en los radio buttons (solo una vez)
        let comprobanteListenersConfigurados = false;
        function configurarComportamientoComprobante() {
            if (comprobanteListenersConfigurados) return;
            const radios = document.querySelectorAll('input[name="TipoComprobante"]');
            radios.forEach(r => r.addEventListener('change', actualizarTotalesVenta));
            comprobanteListenersConfigurados = true;
        }

        // Calcula y actualiza los totales mostrados en el modal según el tipo de comprobante
        function actualizarTotalesVenta() {
            // Tomamos el subtotal desde el servidor (valor seguro) usando invariant culture para evitar comas
            const subtotal = parseFloat('@Model.SubTotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)') || 0;
            const igvRate = 0.18;

            const tipo = document.querySelector('input[name="TipoComprobante"]:checked')?.value || 'PROFORMA';
            let igv = 0;
            let total = subtotal;

            if (tipo === 'PROFORMA') {
                igv = 0;
                total = subtotal;
            } else {
                // BOLETA o FACTURA aplican IGV
                igv = +(subtotal * igvRate);
                // redondeo a 2 decimales
                igv = Math.round(igv * 100) / 100;
                total = Math.round((subtotal + igv) * 100) / 100;
            }

            // Formateo simple a 2 decimales, prefijo S/
            const format = v => 'S/ ' + v.toFixed(2);

            const subtotalEl = document.getElementById('subtotalModal');
            const igvEl = document.getElementById('igvModal');
            const totalEl = document.getElementById('totalModal');
            const totalFooter = document.getElementById('totalFooter');

            if (subtotalEl) subtotalEl.textContent = format(subtotal);
            if (igvEl) igvEl.textContent = format(igv);
            if (totalEl) totalEl.textContent = format(total);
            if (totalFooter) totalFooter.textContent = format(total);
        }

        // Validación del formulario antes de enviar
        document.getElementById('formConvertirVenta')?.addEventListener('submit', function(e) {
            const btn = document.getElementById('btnConfirmarVenta');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Procesando...';

            // La validación de campos requeridos es HTML5
            return true;
        });

        // Buscar al presionar Enter
        document.getElementById('buscadorProducto')?.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                buscarProducto();
            }
        });
    </script>
}