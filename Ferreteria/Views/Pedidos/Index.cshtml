@using Ferreteria.DTOs
@model IEnumerable<PedidoListDto>
@{
    ViewData["Title"] = "Gestión de Pedidos";
    var estados = new[] { "INICIO", "PROCESO", "FINALIZADO", "CANCELADO" };
    var estadoSeleccionado = ViewBag.EstadoSeleccionado as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0"> Pedidos</h2>
        <p class="text-muted mb-0">Gestión de pedidos de clientes</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-lg">
        <i class="fas fa-plus me-2"></i>Nuevo Pedido
    </a>
</div>

<!-- Filtros -->
<div class="card filter-card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-2">
                <label class="form-label fw-bold">Estado</label>
                <select name="estado" class="form-select" >
                    <option value="">-- Todos --</option>
                    @foreach (var est in estados)
                    {
                        <option value="@est" selected="@(ViewBag.EstadoSeleccionado == est)">@est</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Fecha Desde</label>
                <input type="date" name="fechaDesde" class="form-control" value="@ViewBag.FechaDesde" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Fecha Hasta</label>
                <input type="date" name="fechaHasta" class="form-control" value="@ViewBag.FechaHasta" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Búsqueda</label>
                <div class="input-group">
                    <input type="text" name="busqueda" class="form-control"
                           placeholder="N° pedido, cliente..." value="@ViewBag.Busqueda" />
                   
                </div>
            </div>
             
            <div class="col-md-1 d-flex align-items-end justify-content-end gap-1">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search me-2"></i>Buscar
                </button>
            </div>
               
        </form>
    </div>
</div>

<!-- Resumen -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-warning text-dark">
            <div class="card-body text-center">
                <h3>@Model.Count(p => p.Estado == "INICIO")</h3>
                <small>Inicio</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h3>@Model.Count(p => p.Estado == "PROCESO")</h3>
                <small>En Proceso</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h3>@Model.Count(p => p.Estado == "FINALIZADO")</h3>
                <small>Finalizados</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h3>@Model.Count(p => p.Estado == "CANCELADO")</h3>
                <small>Cancelados</small>
            </div>
        </div>
    </div>
</div>

<!-- Tabla de Pedidos -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>N° Pedido</th>
                        <th>Cliente</th>
                        <th>Estado</th>
                        <th>Fecha Pedido</th>
                        <th>Entrega Est.</th>
                        <th>Productos</th>
                        <th>Total</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.NumeroPedido</strong>
                                <div class="small text-muted">@item.UsuarioCreacion</div>
                            </td>
                            <td>
                                <strong>@item.ClienteNombre</strong>
                                <div class="small text-muted">@item.ClienteDocumento</div>
                            </td>
                            <td>
                                <span class="@item.EstadoClass">@item.Estado</span>
                            </td>
                            <td>@item.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @(item.FechaEstimadaEntrega?.ToString("dd/MM/yyyy") ?? "-")
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@item.CantidadProductos</span>
                            </td>
                            <td>
                                <strong>S/ @item.Total.ToString("N2")</strong>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-outline-primary" title="Ver detalles">
                                        <i class="fas fa-eye"></i>
                                    </a>

                                    @if (item.PuedeEliminar)
                                    {
                                        <button type="button" class="btn btn-outline-danger"
                                                onclick="confirmarEliminar('@item.Id', '@item.NumeroPedido')"
                                                title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-clipboard fa-3x mb-3 opacity-25"></i>
                <p>No se encontraron pedidos con los filtros aplicados</p>
            </div>
        }
    </div>
</div>

<!-- Modal Confirmar Eliminación -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i>Confirmar Eliminación</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Está seguro de eliminar el pedido <strong id="numeroPedidoEliminar"></strong>?</p>
                <div class="alert alert-warning">
                    <i class="fas fa-info-circle me-2"></i>
                    Esta acción no se puede deshacer. Solo pedidos en estado INICIO pueden eliminarse.
                </div>
            </div>
            <div class="modal-footer">
                
                <form id="formEliminar" asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="idPedidoEliminar" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Sí, Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmarEliminar(id, numeroPedido) {
            document.getElementById('idPedidoEliminar').value = id;
            document.getElementById('numeroPedidoEliminar').textContent = numeroPedido;
            new bootstrap.Modal(document.getElementById('modalEliminar')).show();
        }
    </script>
}