@model Ferreteria.DTOs.DashboardDto
@{
    ViewData["Title"] = "Dashboard";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Dashboard</h2>
    <span class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
</div>
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="text-muted mb-2">Ventas Hoy</h6>
                        <h3 class="mb-0">S/ @Model.VentasHoy.ToString("N2")</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded">
                        <i class="fas fa-dollar-sign text-primary fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card warning h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="text-muted mb-2">Pedidos Pendientes</h6>
                        <h3 class="mb-0">@Model.PedidosPendientes</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-3 rounded">
                        <i class="fas fa-clock text-warning fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card danger h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="text-muted mb-2">Stock Bajo</h6>
                        <h3 class="mb-0">@Model.ProductosStockBajo</h3>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-3 rounded">
                        <i class="fas fa-box-open text-danger fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card success h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="text-muted mb-2">Productos Activos</h6>
                        <h3 class="mb-0">@Model.ProductosMasVendidos.Count()</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded">
                        <i class="fas fa-check-circle text-success fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row g-4">
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Últimos Pedidos</h5>
                <a asp-controller="Pedidos" asp-action="Index" class="btn btn-sm btn-outline-primary">Ver todos</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>N° Pedido</th>
                                <th>Cliente</th>
                                <th>Estado</th>
                                <th>Total</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pedido in Model.UltimosPedidos)
                            {
                                <tr>
                                    <td><strong>@pedido.NumeroPedido</strong></td>
                                    <td>@pedido.ClienteNombre</td>
                                    <td><span class="@pedido.EstadoClass">@pedido.Estado</span></td>
                                    <td>S/ @pedido.Total.ToString("N2")</td>
                                    <td>@pedido.FechaPedido.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="mb-0">Productos Más Vendidos</h5>
            </div>
            <div class="card-body">
                @foreach (var producto in Model.ProductosMasVendidos.Take(5))
                {
                    <div class="d-flex align-items-center mb-3 p-2 rounded hover-bg-light">
                        <div class="bg-primary bg-opacity-10 p-2 rounded me-3">
                            <i class="fas fa-box text-primary"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0">@producto.Nombre</h6>
                            <small class="text-muted">@producto.CategoriaNombre</small>
                        </div>
                        <span class="badge bg-success">S/ @producto.PrecioVenta.ToString("N2")</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>