@model Ferreteria.DTOs.ReporteVentasDto
@{
    ViewData["Title"] = "Reporte de Ventas";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Reporte de Ventas</h2>
</div>
<div class="card filter-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end" id="filtrosForm">
            <div class="col-md-3">
                <label class="form-label">Fecha Inicio</label>
                <input type="date" name="fechaInicio" id="fechaInicio" class="form-control" value="@DateTime.Now.AddDays(-30).ToString("yyyy-MM-dd")" required>
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha Fin</label>
                <input type="date" name="fechaFin" id="fechaFin" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
            </div>
            <div class="col-md-3">
                <label class="form-label">Agrupación</label>
                <select name="agrupacion" id="agrupacion" class="form-select">
                    <option value="DIARIA">Diaria</option>
                    <option value="SEMANAL">Semanal</option>
                    <option value="MENSUAL">Mensual</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary ">
                    <i class="fas fa-chart-line me-2"></i>Generar Reporte
                </button>
            </div>
        </form>
    </div>
</div>
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body">
                <h6 class="text-muted mb-2">Total Ventas</h6>
                <h3 class="mb-0 text-success">S/ @Model.TotalVentas.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body">
                <h6 class="text-muted mb-2">Cantidad de Ventas</h6>
                <h3 class="mb-0">@Model.CantidadVentas</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body">
                <h6 class="text-muted mb-2">Promedio por Venta</h6>
                <h3 class="mb-0">S/ @Model.PromedioVenta.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body">
                <h6 class="text-muted mb-2">Total Descuentos</h6>
                <h3 class="mb-0 text-warning">S/ @Model.TotalDescuentos.ToString("N2")</h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
     
    <div class="card">
        <div class="card-header bg-white pt-4 px-4">
            <h5 class="mb-0">Top 10 Productos más vendidos</h5>
        </div>
        <div class="card-body">
            <canvas id="topProductosChart" height="200"></canvas>
        </div>
    </div>
     
    
</div>
<p></p>
<div class="row g-4">
     
    <div class="card">
        <div class="card-header bg-white pt-4 px-4">
            <h5 class="mb-0">Ventas por Usuario</h5>
        </div>
        <div class="card-body">
            <canvas id="ventasUsuariosChart" height="200"></canvas>
        </div>
    </div>
     
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    (function () {
        const qs = (name) => document.querySelector(name);

        function getFilters() {
            const fInicio = qs('#fechaInicio').value;
            const fFin = qs('#fechaFin').value;
            const agrup = qs('#agrupacion').value;
            return { fechaInicio: fInicio, fechaFin: fFin, agrupacion: agrup };
        }

        async function fetchJson(url) {
            const resp = await fetch(url, { credentials: 'same-origin' });
            if (!resp.ok) throw new Error('Error al obtener datos');
            return resp.json();
        }

        function buildHorizontalBar(ctx, labels, values, labelText, color = 'rgba(54, 162, 235, 0.8)') {
            if (!ctx) return null;
            return new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: labelText,
                        data: values,
                        backgroundColor: color,
                        borderWidth: 1
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    scales: {
                        x: {
                            beginAtZero: true
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const val = context.parsed.x ?? context.parsed.y;
                                    return labelText + ': ' + val;
                                }
                            }
                        }
                    }
                }
            });
        }

        let chartTop = null;
        let chartUsuarios = null;

        async function loadCharts() {
            try {
                const f = getFilters();
                const params = new URLSearchParams({
                    fechaInicio: f.fechaInicio,
                    fechaFin: f.fechaFin,
                    agrupacion: f.agrupacion
                });

                // Top productos
                const topUrl = '/Ventas/TopProductos?' + new URLSearchParams({ fechaInicio: f.fechaInicio, fechaFin: f.fechaFin, top: 10 });
                const topData = await fetchJson(topUrl);
                const topLabels = topData.map(x => x.productoNombre);
                const topValues = topData.map(x => x.cantidadVendida);

                const topCtx = document.getElementById('topProductosChart').getContext('2d');
                if (chartTop) { chartTop.destroy(); chartTop = null; }
                chartTop = buildHorizontalBar(topCtx, topLabels, topValues, 'Cantidad vendida', 'rgba(75, 192, 192, 0.8)');

                // Ventas por usuario
                const usuariosUrl = '/Ventas/VentasPorUsuarios?' + params.toString();
                const usuariosData = await fetchJson(usuariosUrl);
                const usuariosLabels = usuariosData.map(x => x.usuarioNombre);
                const usuariosValues = usuariosData.map(x => parseFloat(x.totalVentas));

                const usuariosCtx = document.getElementById('ventasUsuariosChart').getContext('2d');
                if (chartUsuarios) { chartUsuarios.destroy(); chartUsuarios = null; }
                chartUsuarios = buildHorizontalBar(usuariosCtx, usuariosLabels, usuariosValues, 'Total ventas', 'rgba(255, 159, 64, 0.85)');

            } catch (ex) {
                console.error(ex);
            }
        }

        // Cargar charts al abrir la página con los valores del form
        document.addEventListener('DOMContentLoaded', function () {
            // Si la URL contiene parámetros, intentar rellenar los inputs con ellos
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('fechaInicio')) qs('#fechaInicio').value = urlParams.get('fechaInicio');
            if (urlParams.has('fechaFin')) qs('#fechaFin').value = urlParams.get('fechaFin');
            if (urlParams.has('agrupacion')) qs('#agrupacion').value = urlParams.get('agrupacion');

            loadCharts();
        });

        // Volver a cargar charts al enviar el formulario
        qs('#filtrosForm').addEventListener('submit', function () {
            // Dejar que el formulario haga GET para actualizar la URL; luego cargar charts al recargar página.
            // Para evitar navegación completa y hacer petición AJAX, comentar la línea anterior y descomentar la siguiente:
            // event.preventDefault(); loadCharts();
        });

    })();
</script>
}