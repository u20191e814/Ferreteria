@* FerreteriaApp.Web/Views/Clientes/Edit.cshtml *@
@model Ferreteria.Entities.Cliente
@{
    ViewData["Title"] = "Editar cliente";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
         
        <h2 class="mb-0">Modificar información de @Model.NombreCompleto</h2>
       
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info">
            <i class="fas fa-eye me-2"></i>Ver Detalle
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <form asp-action="Edit" method="post" class="needs-validation" novalidate>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="FechaCreacion" />

            <div class="card">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0"><i class="fas fa-user-edit me-2 text-primary"></i>Información General</h5>
                </div>
                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        @* Documento (solo lectura) *@
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Tipo de Documento</label>
                            <input type="text" class="form-control" value="@Model.TipoDocumento" readonly>
                            <div class="form-text text-muted">No se puede modificar el tipo de documento</div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Número de Documento</label>
                            <div class="input-group">
                                <input type="text" class="form-control" value="@Model.NumeroDocumento" readonly>
                                <span class="input-group-text bg-success text-white">
                                    <i class="fas fa-check"></i>
                                </span>
                            </div>
                            <div class="form-text text-muted">El número de documento no es editable</div>
                        </div>

                        @* Nombre *@
                        <div class="col-12">
                            <label asp-for="NombreCompleto" class="form-label fw-bold">
                                Nombre Completo / Razón Social <span class="text-danger">*</span>
                            </label>
                            <input asp-for="NombreCompleto" class="form-control form-control-lg" required maxlength="200">
                            <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                        </div>

                        @* Dirección *@
                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label fw-bold">Dirección</label>
                            <textarea asp-for="Direccion" class="form-control" rows="2" maxlength="300"></textarea>
                            <span asp-validation-for="Direccion" class="text-danger small"></span>
                        </div>

                        @* Contacto *@
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label fw-bold">
                                Teléfono <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                <input asp-for="Telefono" class="form-control" required maxlength="20">
                            </div>
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-bold">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <input asp-for="Email" class="form-control" maxlength="150" type="email">
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        @* Estado *@
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-2">
                                <input asp-for="Activo" class="form-check-input" type="checkbox">
                                <label class="form-check-label fw-bold" asp-for="Activo">
                                    Cliente Activo
                                </label>
                                <div class="form-text">Desmarque para desactivar temporalmente</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Configuración *@
            <div class="card mt-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="mb-0"><i class="fas fa-cog me-2 text-success"></i>Configuración de Cliente</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input asp-for="EsFrecuente" class="form-check-input" type="checkbox" id="esFrecuente" onchange="toggleDescuento()">
                                <label class="form-check-label fw-bold" for="esFrecuente">
                                    <i class="fas fa-star text-warning me-1"></i>Cliente Frecuente
                                </label>
                            </div>
                            <div class="form-text">Beneficios especiales y descuentos</div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DescuentoPreferencial" class="form-label fw-bold">
                                Descuento Preferencial (%)
                            </label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-percentage"></i></span>
                                <input asp-for="DescuentoPreferencial" class="form-control"
                                       type="number" min="0" max="50" step="0.01" id="descuentoPreferencial">
                            </div>
                        </div>
                    </div>

                    @* Historial del cliente *@
                    <div class="mt-4 p-3 bg-light rounded">
                        <h6 class="mb-3"><i class="fas fa-history me-2"></i>Información del Sistema</h6>
                        <div class="row g-2 small">
                            <div class="col-md-6">
                                <span class="text-muted">Fecha de registro:</span>
                                <strong>@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</strong>
                            </div>
                            <div class="col-md-6">
                                <span class="text-muted">Estado:</span>
                                <span class="badge @(Model.Activo ? "bg-success" : "bg-danger")">
                                    @(Model.Activo ? "Activo" : "Inactivo")
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <button type="button" class="btn btn-outline-danger btn-lg" onclick="confirmarEliminar()">
                    <i class="fas fa-trash me-2"></i>Eliminar
                </button>
                <div class="d-flex gap-2">
                    <button type="reset" class="btn btn-outline-secondary btn-lg">
                        <i class="fas fa-undo me-2"></i>Restaurar
                    </button>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save me-2"></i>Guardar Cambios
                    </button>
                </div>
            </div>
        </form>

        
        
    </div>

    @* Panel lateral *@
    <div class="col-lg-4">
        <div class="card sticky-top" style="top: 20px;">
            <div class="card-header bg-primary text-white border-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-user me-2"></i>Resumen</h5>
            </div>
            <div class="card-body p-4 text-center">
                <div class="bg-primary bg-opacity-10 rounded-circle p-4 mx-auto mb-3" style="width: 100px; height: 100px; display: flex; align-items: center; justify-content: center;">
                    <i class="fas @(Model.TipoDocumento == "RUC" ? "fa-building" : "fa-user") fa-3x text-primary"></i>
                </div>

                <h5 class="mb-1">@Model.NombreCompleto</h5>
                <p class="text-muted mb-3">
                    <span class="badge @(Model.TipoDocumento == "DNI" ? "badge-dni" : Model.TipoDocumento == "RUC" ? "badge-ruc" : "badge-ce")">
                        @Model.TipoDocumento
                    </span>
                    <code class="d-block mt-1">@Model.NumeroDocumento</code>
                </p>

               @*  <div class="d-grid gap-2">
                    <a href="tel:@Model.Telefono" class="btn btn-outline-primary">
                        <i class="fas fa-phone me-2"></i>Llamar
                    </a>
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <a href="mailto:@Model.Email" class="btn btn-outline-info">
                            <i class="fas fa-envelope me-2"></i>Enviar Email
                        </a>
                    }
                </div> *@

                <hr>

                <div class="text-start small">
                    <div class="mb-2">
                        <i class="fas fa-map-marker-alt text-muted me-2"></i>
                        @(Model.Direccion ?? "Sin dirección registrada")
                    </div>
                    <div class="mb-2">
                        <i class="fas fa-calendar text-muted me-2"></i>
                        Cliente desde @Model.FechaCreacion.ToString("MMM yyyy")
                    </div>
                    @if (Model.EsFrecuente)
                    {
                        <div class="text-warning">
                            <i class="fas fa-star me-2"></i>
                            Cliente frecuente @(Model.DescuentoPreferencial > 0 ? $"- {Model.DescuentoPreferencial}% dto." : "")
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Delete" method="post">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i>Confirmar Eliminación</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" value="@Model.Id" id="clienteIdEliminar" />
                    <p>¿Está seguro de que desea eliminar al cliente  @Model.NombreCompleto ?</p>
                    <div class="alert alert-warning">
                        <i class="fas fa-info-circle me-2"></i>
                        Esta acción no se puede deshacer. El cliente ya no aparecerá en las búsquedas pero sus ventas históricas se mantendrán.
                    </div>
                </div>
                <div class="modal-footer">
                     
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Sí, Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function toggleDescuento() {
            const esFrecuente = document.getElementById('esFrecuente').checked;
            const descuentoInput = document.getElementById('descuentoPreferencial');
            descuentoInput.disabled = !esFrecuente;
            if (!esFrecuente) descuentoInput.value = '0';
        }

        function confirmarEliminar() {
           
            new bootstrap.Modal(document.getElementById('modalEliminar')).show();
            
        }

        // Inicializar estado del descuento
        document.addEventListener('DOMContentLoaded', function() {
            toggleDescuento();
        });

        // Validación Bootstrap
        (function () {
            'use strict';
            var forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
}